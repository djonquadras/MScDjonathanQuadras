@ARTICLE{Liu20123787,
author={Liu, F. and Gao, J. and Yu, W. and Jin, X.},
title={AGIOT: A model of the internet of things used in agriculture},
journal={Information},
year={2012},
volume={15},
number={9},
pages={3787-3792},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84865030900&partnerID=40&md5=fbd1bcd5892d617dbc1bd25d5ceb8fc6},
affiliation={College of Science, Huazhong Agriculture University, No.1, Shizishan Street, Hongshan District, Wuhan, Hubei Province 430070, China},
abstract={Nowadays, more and more researchers focus on the Internet of Things (IoT), which blurs the line between virtual and real worlds. However, few of them concern how to realize this kind of applications. In order to do some further study on the software implementation, in this paper, we propose a model of Internet of things used in agriculture, named AGIOT. A new four-layer architecture of the IoT application is established and some key issues in system implementation are discussed. Further more, a new middle layer framework is presented based on service oriented architecture (SOA), which makes users access to real-time data easily through a high-level abstract interface based on web services. In order to increase the yield and improve the quality of plant, an intelligent algorithm based on reinforcement learning is introduced. The model we proposed is feasible. ©2012 International Information Institute.},
author_keywords={Internet of things;  Service oriented architecture;  Web service;  Wireless sensor network},
references={Weber, R.H., Internet of things- Need for a new legal environment? (2009) Computer Law & Security Review, 25 (6), pp. 522-527; Conti, J.P., The Internet of things (2006) Communications Engineer, 4 (6), pp. 20-25; Miao, W., Ting-Jie, L., Fei-Yang, L., Jing, S., Hui-Ying, D., Research on the architecture of Internet of Things (2010) 2010 3rd International Conference on Advanced Computer Theory and Engineering(ICACTE), pp. 484-487. , IEEE Computer Society, Chengdu; Zhiyong, S., Kui, L., Sniping, Y., Qingbo, O., Design and implementation of the mobile internet of things based on td-scdma network (2010) 2010 IEEE International Conference on Information Theory and Information Security(ICLTIS), pp. 954-957. , IEEE Computer Society, Beijing; Huansheng, N., Ziou, W., Future internet of things architecture: Like mankind neural system or social organization framework? (2011) Communications Letters, 15 (4), pp. 461-463; Guinard, D., Trifa, V., Karnouskos, S., Spiess, P., Savio, D., Interacting with the SOA-based internet of things: Discovery, query, selection, and on-demand provisioning of web services (2010) IEEE Transactions on Services Computing, 3 (3), pp. 223-235; Qian, Z., Ruicong, W., Qi, C., Yan, L., Weijun, Q., IOT gateway: Bridging wireless sensor networks into internet of things (2010) 2010 IEEE/IFIP 8th International Conference on Embedded and Ubiquitous Computing (EUC), pp. 347-352. , IEEE Computer Society, Hong Kong; Sungmin, H., Daeyoung, K., Minkeun, H., Sungho, B., Sang Jun, P., Wooyoung, J., Jae-Eon, K., SNAIL: An IP-based wireless sensor network approach to the internet of things (2010) Wireless Communications, 17 (6), pp. 34-42},
correspondence_address1={Gao, J.; College of Science, No.1, Shizishan Street, Hongshan District, Wuhan, Hubei Province 430070, China; email: happytimehn@163.com},
issn={13434500},
