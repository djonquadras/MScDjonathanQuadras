@ARTICLE{Moustafa2018296,
author={Moustafa, A. and Ito, T.},
title={A deep reinforcement learning approach for large-scale service composition},
journal={Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bioinformatics)},
year={2018},
volume={11224 LNAI},
pages={296-311},
doi={10.1007/978-3-030-03098-8_18},
note={cited By ; Conference of 21st International Conference on Principles and Practice of Multi-Agent Systems, PRIMA 2018 ; Conference Date: 29 October 2018 Through 2 November 2018;  Conference Code:220189},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85056460977&doi=10.1007%2f978-3-030-03098-8_18&partnerID=40&md5=8094b59c23b7a07a568f1a443ad9ddee},
affiliation={Nagoya Instititute of Technology, Nagoya, Japan},
abstract={As service-oriented environments become widespread, there exists a pressing need for service compositions to cope with the high scalability, complexity, heterogeneity and dynamicity features inherent in these environments. In this context, reinforcement learning has emerged as a powerful tool that empowers adaptive service composition in open and dynamic environments. However, most of the existing implementations of reinforcement learning algorithms for service compositions are inefficient and fail to handle large-scale service environments. Towards this end, this paper proposes a novel approach for adaptive service composition in dynamic and large-scale environments. The proposed approach employs deep reinforcement learning in order to address large-scale service environments with large number of service providers. Experimental results show the ability and efficiency of the proposed approach to provide successful service compositions in dynamic and large-scale service environments. © Springer Nature Switzerland AG 2018.},
author_keywords={Cloud computing;  Deep reinforcement learning;  Service composition},
keywords={Cloud computing;  Data privacy;  Information services;  Learning algorithms;  Multi agent systems;  Network security;  Quality of service;  Reinforcement learning, Adaptive services;  Dynamic environments;  High scalabilities;  Number of services;  Reinforcement learning approach;  Service compositions;  Service environment;  Service-oriented environment, Deep learning},
references={Al-Masri, E., Mahmoud, Q.H., Discovering the best web service (2007) Proceedings of WWW, pp. 1257-1258; Lee, C.-H., Hwang, S.-Y., Yen, I.-L., A service pattern model for flexible service composition (2012) Proceedings of IEEE ICWS, pp. 626-627. , June; Chiu, D., Agrawal, G., Cost and accuracy aware scientific workflow composition for service-oriented environments (2012) IEEE Trans. Serv. Comput., 4 (2), pp. 140-152; Gelly, S., Silver, D., Combining online and offline knowledge in UCT (2007) Proceedings of ICML, ICML 2007, pp. 273-280. , ACM, New York; Huang, J., Liu, Y., Yu, R., Duan, Q., Tanaka, Y., Modeling and algorithms for QoS-aware service composition in virtualization-based cloud computing (2013) IEICE Trans, 96 B (1), pp. 10-19; Jureta, I.J., Faulkner, S., Achbany, Y., Saerens, M., Dynamic web service composition within a service-oriented architecture (2007) IEEE International Conference on Web Services, ICWS 2007, pp. 304-311. , July; Klein, A., Ishikawa, F., Honiden, S., SanGA: A self-adaptive network-aware approach to service composition (2014) IEEE Trans. Serv. Comput., 7 (3), pp. 452-464; Krizhevsky, A., Sutskever, I., Hinton, G.E., ImageNet classification with deep convolutional neural networks (2012) Proceedings of NIPS, NIPS 2012, pp. 1097-1105. , Curran Associates Inc; Lawrence, S., Giles, C.L., Tsoi, A.C., Back, A.D., Face recognition: A convolutional neural-network approach (1997) IEEE Trans. Neural Netw., 8 (1), pp. 98-113; Li, D., Cheung, D., Shi, X., Ng, V., Uncertainty reasoning based on cloud models in controllers (1998) Comput. Math. Appl., 35 (3), pp. 99-123; Li, H., Dagli, C.H., Enke, D., Short-term stock market timing prediction under reinforcement learning schemes (2007) Proceedings of IEEE ADPRL, pp. 233-240; Mnih, V., Human-level control through deep reinforcement learning (2015) Nature, 518 (7540), pp. 529-533; Moustafa, A., Zhang, M., Towards proactive web service adaptation (2012) Caise 2012. LNCS, 7328, pp. 473-485. , https://doi.org/10.1007/978-3-642-31095-931, Ralyté, J., Franch, X., Brinkkemper, S., Wrycza, S. (eds.), Springer, Heidelberg; Moustafa, A., Zhang, M., Multi-objective service composition using reinforcement learning (2013) ICSOC 2013. LNCS, 8274, pp. 298-312. , https://doi.org/10.1007/978-3-642-45005-121, Basu, S., Pautasso, C., Zhang, L., Fu, X. (eds.), Springer, Heidelberg; Schaul, T., Quan, J., Antonoglou, I., Silver, D., Prioritized experience replay (2016) Proceedings of ICLR, Puerto Rico; Silver, D., Mastering the game of go with deep neural networks and tree search (2016) Nature, 529 (7587), pp. 484-489; Tang, H., Liu, W., Zhou, L., Web service composition method using hierarchical reinforcement learning (2012) Green Communications and Networks. LNEE, 113, pp. 1429-1438. , https://doi.org/10.1007/978-94-007-2169-2170, Yang, Y., Ma, M. (eds.), Springer, Dordrecht; van Hasselt, H., Double q-learning (2010) Proceedings of NIPS, pp. 2613-2621. , Curran Associates Inc; van Hasselt, H., Guez, A., Silver, D., Deep reinforcement learning with double q-learning (2016) Proceedings of AAAI, AAAI 2016, pp. 2094-2100. , AAAI Press; Wang, H., Chen, X., Wu, Q., Yu, Q., Zheng, Z., Bouguettaya, A., Integrating on-policy reinforcement learning with multi-agent techniques for adaptive service composition (2014) ICSOC 2014. LNCS, 8831, pp. 154-168. , https://doi.org/10.1007/978-3-662-45391-911, Franch, X., Ghose, A.K., Lewis, G.A., Bhiri, S. (eds.), Springer, Heidelberg; Wang, H., Wang, X., A novel approach to large-scale services composition (2013) Apweb 2013. LNCS, 7808, pp. 220-227. , https://doi.org/10.1007/978-3-642-37401-223, Ishikawa, Y., Li, J., Wang, W., Zhang, R., Zhang, W. (eds.), Springer, Heidelberg; Wang, H., Zhou, X., Zhou, X., Liu, W., Li, W., Bouguettaya, A., Adaptive service composition based on reinforcement learning (2010) ICSOC 2010. LNCS, 6470, pp. 92-107. , https://doi.org/10.1007/978-3-642-17358-57, Maglio, P.P., Weske, M., Yang, J., Fantinato, M. (eds.),