@ARTICLE{Moustafa2012473,
author={Moustafa, A. and Zhang, M.},
title={Towards proactive web service adaptation},
journal={Lecture Notes in Computer Science (including subseries Lecture Notes in Artificial Intelligence and Lecture Notes in Bioinformatics)},
year={2012},
volume={7328 LNCS},
pages={473-485},
doi={10.1007/978-3-642-31095-9_31},
note={cited By ; Conference of 24th International Conference on Advanced Information Systems Engineering, CAiSE 2012 ; Conference Date: 25 June 2012 Through 29 June 2012;  Conference Code:93528},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84867790979&doi=10.1007%2f978-3-642-31095-9_31&partnerID=40&md5=4ecb1d0c153fd0ef6e63150136d3b9ad},
affiliation={School of Computer Science and Software Engineering, University of Wollongong, Gwnneville NSW 2500, Australia},
abstract={With the rapid development of web service technology, next generations of web service applications need to be able to predict problems, such as potential degradation scenarios, future erroneous behaviors and deviations from expected behaviors, and move towards resolving those problems not just reactively, but even proactively, i.e., before the problems occur. Service oriented applications are thus driven by the requirements that bring the concepts of decentralization, dynamism, adaptation, and automation to an extreme. In this paper, an approach is proposed that depends mainly on the concept of proactive adaptation by the use of reinforcement learning to achieve an autonomous dynamic behavior of web service composition considering potential degradation and emergence in QoS values. Experimental results show the effectiveness of the proposed approach in dynamic web service composition environments. © 2012 Springer-Verlag Berlin Heidelberg.},
author_keywords={dynamic composition;  proactive adaptation;  Web services},
keywords={Autonomous dynamics;  Dynamic composition;  Dynamic web service composition;  proactive adaptation;  Service oriented application;  Web service adaptation;  Web service applications;  Web service composition;  Web service technology, Information systems;  Quality of service;  Reinforcement learning;  Systems engineering;  Websites, Web services},
references={Agarwal, V., Jalote, P., From specification to adaptation: An integrated qos-driven approach for dynamic adaptation of web service compositions (2010) Proc. IEEE Int Web Services (ICWS) Conf., pp. 275-282; Berardi, D., Calvanese, D., De Giacomo, G., Lenzerini, M., Mecella, M., Automatic composition of E-services that export their behavior (2003) ICSOC 2003. LNCS, 2910, pp. 43-58. , Orlowska, M.E., Weerawarana, S., Papazoglou, M.P., Yang, J. (eds.). Springer, Heidelberg; Chen, G., Cao, W., Chen, X., Wu, M., Multi-agent q-learning with joint state value approximation (2011) Proc. 30th Chinese Control Conf (CCC), pp. 4878-4882; Clausen, C., Wechsler, H., (2000) Quad-q-learning, 11 (2), pp. 279-294; Doshi, P., Dynamic workflow composition using markov decision processes (2005) International Journal of Web Services Research, 2, pp. 1-17; Gaaloul, K., Walid Godart, C., Log-based mining techniques applied to web service composition reengineering (2008) Service Oriented Computing and Applications, 2, pp. 93-110. , doi:10.1007/s11761-008-0023-6; Gao, A., Yang, D., Tang, S., Zhang, M., Web service composition using Markov decision processes (2005) WAIM 2005. LNCS, 3739, pp. 308-319. , Fan, W., Wu, Z., Yang, J. (eds.). Springer, Heidelberg; Gerede, C.E., Ibarra, O.H., Ravikumar, B., Su, J., Minimum-cost delegation in service composition (2008) Theor. Comput. Sci., 409, pp. 417-431; Gooneratne, N., Tari, Z., Matching independent global constraints for composite web services (2008) Proceeding of the 17th International Conference on World Wide Web, WWW 2008, pp. 765-774. , ACM, New York; Lee, J.W., Stock price prediction using reinforcement learning (2001) Proceedings of IEEE International Symposium on Industrial Electronics, ISIE 2001, 1, pp. 690-695; Li, H., Dagli, C.H., Enke, D., Short-term stock market timing prediction under reinforcement learning schemes (2007) IEEE International Symposium on Approximate Dynamic Programming and Reinforcement Learning, ADPRL 2007, pp. 233-240. , April; Oh, S.-C., Lee, D., Kumara, S.R.T., A comparative illustration of ai planning-based web services composition (2006) SIGecom Exch., 5, pp. 1-10; Prezerakos, G.N., Tselikas, N.D., Cortese, G., Model-driven composition of contextaware web services using contextuml and aspects (2007) IEEE International Conference on Web Services, ICWS 2007, pp. 320-329. , July; Rao, J., Su, X., A survey of automated web service composition methods (2005) SWSWPC 2004. LNCS, 3387, pp. 43-54. , Cardoso, J., Sheth, A.P. (eds.). Springer, Heidelberg; Tang, R., Zou, Y., An approach for mining web service composition patterns from execution logs (2010) Proc. IEEE Int Web Services (ICWS) Conf., pp. 678-679; Watkins, C., (1989) Learning from Delayed Rewards, , PhD thesis, Cambridge University, England; Xu, Y., Tang, S., Xu, Y., Tang, Z., Towards aspect oriented web service composition with uml (2007) 6th IEEE/ACIS International Conference on Computer and Information Science, ICIS 2007, pp. 279-284. , July; Zahoor, E., Perrin, O., Godart, C., Rule-based semi automatic web services composition (2009) Proceedings of the 2009 Congress on Services-I, pp. 805-812. , IEEE Computer Society, Washington, DC},
correspondence_address1={Moustafa, A.; School of Computer Science and Software Engineering, , Gwnneville NSW 2500, Australia; email: aase995@uowmail.edu.au},
