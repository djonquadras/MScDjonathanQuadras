@ARTICLE{Qiu2020203,
author={Qiu, C. and Yao, H. and Yu, F.R. and Jiang, C. and Guo, S.},
title={A Service-Oriented Permissioned Blockchain for the Internet of Things},
journal={IEEE Transactions on Services Computing},
year={2020},
volume={13},
number={2},
pages={203-215},
doi={10.1109/TSC.2019.2948870},
art_number={8880544},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85083274156&doi=10.1109%2fTSC.2019.2948870&partnerID=40&md5=4f84f48034329e4a1e58bc0b355f996e},
affiliation={College of Intelligence and Computing, School of Computer Science and Technology, Tianjin University, Tianjin, China; Information and Communication Engineering, Beijing University of Posts and Telecommunications, Beijing, China; Systems and Computer Engineering, Carleton University, Ottawa, ON, Canada; Space Center, Tsinghua University, Beijing, China; Department of Computing, Hong Kong Polytechnic University, Hong Kong},
abstract={Recently, the emergence of blockchain has stirred great interests in the field of Internet of Things (IoT). However, numerous non-trivial problems in the current blockchain system prevent it from being used as a generic platform for large-scale services and applications in IoT. One notable drawback is the scalability problem. Lots of projects and researches have been done to solve this problem. Nevertheless, they do not consider different users' conditions, only using a single consensus protocol as the best fit one, as well as the IoT system is heavily constrained by computing and networking resources. In this article, we study a permissioned blockchain-based IoT architecture. In order to improve the scalability of the blockchain system and meet the needs of different users, we propose a service-oriented permissioned blockchain, where different consensus protocols are launched according to users' quality of service (QoS) requirements. Specially, we quantify a few popular consensus protocols. Additionally, we select block producers, which need a great number of computation resources, as well as dynamically allocate network bandwidth to the blockchain system. We formulate consensus protocols selection, block producers selection, and network bandwidth allocation as a joint optimization problem. We then use a dueling deep reinforcement learning approach to solve the problem. Simulation results demonstrate the effectiveness of our proposed scheme. © 2008-2012 IEEE.},
author_keywords={Byzantine fault tolerance;  deep reinforcement learning;  Internet of things (IoT);  permissioned blockchain;  service-oriented},
keywords={Bandwidth;  Blockchain;  Deep learning;  Internet protocols;  Quality of service;  Reinforcement learning;  Scalability, Computation resources;  Consensus protocols;  Internet of Things (IOT);  Non trivial problems;  Qualityof-service requirement (QoS);  Reinforcement learning approach;  Scalability problems;  Services and applications, Internet of things},
references={Chen, L., Zhao, N., Chen, Y., Yu, F.R., Wei, G., Over-the-air computation for IoT networks: Computing multiple functions with antenna arrays (2018) IEEE Internet Things J., 5 (6), pp. 5296-5306. , Dec; Li, X., Wang, X., Wan, P., Han, Z., Leung, V.C.M., Hierarchical edge caching in device-to-device aided mobile networks: Modeling, optimization, and design (2018) IEEE J. Sel. Areas Commun., 36 (8), pp. 1768-1785. , Aug; Middleton, P., Kjeldsen, P., Tully, J., Forecast: The Internet of Things, worldwide (2013) Gartner, , https://www.gartner.com/doc/2625419/forecast-internet-thingsworldwide-; Novo, O., Blockchain meets IoT: An architecture for scalable access management in IoT (2018) IEEE Internet Things J., 5 (2), pp. 1184-1195. , Apr; Yu, F.R., (2018) VDLT: A Service-oriented Blockchain System with Virtualization and Decoupled Management/control and Execution, , arXiv preprint arXiv:1809. 00290; Yao, H., Mai, T., Wang, J., Ji, Z., Jiang, C., Qian, Y., Resource trading in blockchain-based industrial Internet of Things (2019) IEEE Trans. Ind. Informat., 15 (6), pp. 3602-3609. , Jun; Li, X., Li, D., Wan, J., Liu, C., Imran, M., Adaptive transmission optimization in SDN-based industrial Internet of Things with edge computing (2018) IEEE Internet Things J., 5 (3), pp. 1351-1360. , Jun; (2019) EOSIO, , https://eos.io, Last Accessed on: Nov. 8; (2019) Zilliqa, , https://zilliqa.com/, Last Accessed on: Nov. 11; (2019) Plasma, , http://plasma.io/, Last Accessed on: Nov. 8; Corcoran, P., Datta, S.K., Mobile-edge computing and the internet of things for consumers: Extending cloud computing and services to the edge of the network (2016) IEEE Consum. Electron. Mag., 5 (4), pp. 73-74. , Oct; Yu, F.R., Virtualization for distributed ledger technology (vDLT) (2018) IEEE Access, 6, pp. 25019-25028; Castro, M., Liskov, B., Practical byzantine fault tolerance and proactive recovery (2002) ACM Trans. Comput. Syst., 20 (4), pp. 398-461; Kotla, R., Alvisi, L., Zyzzyva: Speculat