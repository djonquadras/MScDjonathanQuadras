@ARTICLE{Wu20212076,
author={Wu, W. and Chen, N. and Zhou, C. and Li, M. and Shen, X. and Zhuang, W. and Li, X.},
title={Dynamic RAN Slicing for Service-Oriented Vehicular Networks via Constrained Learning},
journal={IEEE Journal on Selected Areas in Communications},
year={2021},
volume={39},
number={7},
pages={2076-2089},
doi={10.1109/JSAC.2020.3041405},
art_number={9277604},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85097365905&doi=10.1109%2fJSAC.2020.3041405&partnerID=40&md5=f92c535261e8f835576bab5ae2ba410a},
affiliation={Department of Electrical and Computer Engineering, University of Waterloo, Waterloo, ON  N2L 3G1, Canada; Huawei Technologies Canada Inc., Ottawa, ON  K2K 3J1, Canada},
abstract={In this paper, we investigate a radio access network (RAN) slicing problem for Internet of vehicles (IoV) services with different quality of service (QoS) requirements, in which multiple logically-isolated slices are constructed on a common roadside network infrastructure. A dynamic RAN slicing framework is presented to dynamically allocate radio spectrum and computing resource, and distribute computation workloads for the slices. To obtain an optimal RAN slicing policy for accommodating the spatial-temporal dynamics of vehicle traffic density, we first formulate a constrained RAN slicing problem with the objective to minimize long-term system cost. This problem cannot be directly solved by traditional reinforcement learning (RL) algorithms due to complicated coupled constraints among decisions. Therefore, we decouple the problem into a resource allocation subproblem and a workload distribution subproblem, and propose a two-layer constrained RL algorithm, named Resource Allocation and Workload diStribution (RAWS) to solve them. Specifically, an outer layer first makes the resource allocation decision via an RL algorithm, and then an inner layer makes the workload distribution decision via an optimization subroutine. Extensive trace-driven simulations show that the RAWS effectively reduces the system cost while satisfying QoS requirements with a high probability, as compared with benchmarks. © 1983-2012 IEEE.},
author_keywords={constrained reinforcement learning;  coupled constraint;  RAN slicing;  vehicular networks;  workload distribution},
keywords={Quality of service;  Reinforcement learning;  Resource allocation;  Vehicle to vehicle communications, Computing resource;  Coupled constraints;  Network infrastructure;  Qualityof-service requirement (QoS);  Resource allocation decision;  Trace driven simulation;  Traditional reinforcements;  Work-load distribution, Radio access networks},
funding_details={Natural Sciences and Engineering Research Council of CanadaNatural Sciences and Engineering Research Council of Canada, NSERC},
funding_text 1={Manuscript received July 15, 2020; revised September 27, 2020; accepted October 27, 2020. Date of publication December 2, 2020; date of current version June 17, 2021. This work was supported in part by the Natural Sciences and Engineering Research Council (NSERC) and in part by Huawei Canada. (Corresponding author: Mushu Li.) Wen Wu, Nan Chen, Conghao Zhou, Mushu Li, Xuemin Shen, and Weihua Zhuang are with the Department of Electrical and Computer Engineering, University of Waterloo, Waterloo, ON N2L 3G1, Canada (e-mail: w77wu@uwaterloo.ca; n37chen@uwaterloo.ca; c89zhou@uwaterloo.ca; m475li@uwaterloo.ca; sshen@uwaterloo.ca; wzhuang@uwaterloo.ca).},
references={Liang, L., Peng, H., Li, G.Y., Shen, X., Vehicular communications: A physical layer perspective (2017) Ieee Trans. Veh. Technol., 66 (12), pp. 10647-10659. , Dec; Lu, N., Cheng, N., Zhang, N., Shen, X., Mark, J.W., Connected vehicles: Solutions and challenges (2014) Ieee Internet Things J., 1 (4), pp. 289-299. , Aug; (2018) Global Autonomous Driving Market Outlook, , https://info.microsoft.com/ww-landing-Global-Autonomous-Driving-Market-Outlook-Report-eBook.html?lcid=en-us, Microsoft; Lin, S.-C., The architectural implications of autonomous driving: Constraints and acceleration (2018) Proc. 23rd Int. Conf. Archit. Support Program. Lang. Oper. Syst., pp. 751-766. , Mar; Zhang, J., Letaief, K.B., Mobile edge intelligence and computing for the Internet of vehicles (2020) Proc. Ieee, 108 (2), pp. 246-261. , Feb; Xu, J., Chen, L., Zhou, P., Joint service caching and task offloading for mobile edge computing in dense networks (2018) Proc. Ieee Conf. Comput. Commun. (INFOCOM), pp. 207-215. , Apr; Qiao, J., He, Y., Shen, X.S., Improving video streaming quality in 5G enabled vehicular networks (2018) Ieee Wireless Commun., 25 (2), pp. 133-139. , Apr; Shen, X., AI-Assisted network-slicing based next-generation wireless networks (2020) Ieee Open J. Veh. Technol., 1, pp. 45-66. , Jan; Campolo, C., Molinaro, A., Iera, A., Menichella, F., 5G network slicing for Vehicle-To-Everything services (2017) Ieee Wireless Commun., 24 (6), pp. 38-45. , Dec; Zhang, S., Luo, H., Li, J., Shi, W., Shen, X., Hierarchical soft slicing to meet multi-dimensional QoS demand in cache-enabled vehicular networks (2020) Ieee Trans. Wireless Commun., 19 (3), pp. 2150-2162. , Mar; Li, M., Gao, J., Zhao, L., Shen, X., Deep reinforcement learning for collaborative edge computing in vehicular networks (2020) Ieee Trans. Cognit. Commun. Netw., , early access, Jun. 17; Lillicrap, T.P., Continuous control with deep reinforcement learning (2016) Proc. Iclr, pp. 1-14; Fujimoto, S., Van Hoof, H., Meger, D., Addressing function approximation error in actor-critic methods (2018) Proc. Icml, pp. 1587-1596; (2017) Telecommunication Management; Study on Management and Orchestration of Network Slicing for Next Generation Network (Release 15)., , document 3GPP TR 28.801 V2.0.1, Sep; Afolabi, I., Taleb, T., Samdanis, K., Ksentini, A., Flinck, H., Network slicing and softwarization: A survey on principles, enabling technologies, and solutions (2018) Ieee Commun. Surveys Tuts., 20 (3), pp. 2429-2453. , 3rd Quart; Foukas, X., Marina, M.K., Kontovasilis, K., Orion: RAN slicing for a flexible and cost-effective multi-service mobile network architecture (2017) Proc. 23rd Annu. Int. Conf. Mobile Comput. Netw., pp. 127-140. , Oct; Ye, Q., Zhuang, W., Zhang, S., Jin, A.-L., Shen, X., Li, X., Dynamic radio resource slicing for a two-Tier heterogeneous wireless network (2018) Ieee Trans. Veh. Technol., 67 (10), pp. 9896-9910. , Oct; Xiao, Y., Krunz, M., Dynamic network slicing for scalable fog computing systems with energy harvesting (2018) Ieee J. Sel. Areas Commun., 36 (12), pp. 2640-2654. , Dec; Li, J., A hierarchical soft RAN slicing framework for differentiated service provisioning (2020) Ieee Wireless Commun., , early access, Apr. 22; Zhuang, W., Ye, Q., Lyu, F., Cheng, N., Ren, J., SDN/NFV-empowered future IoV with enhanced communication, computing, and caching (2020) Proc. Ieee, 108 (2), pp. 274-291. , Feb; Gutterman, C., Grinshpun, E., Sharma, S., Zussman, G., RAN resource usage prediction for a 5G slice broker (2019) Proc. 20th Acm Int. Symp. Mobile Ad Hoc Netw. Comput., pp. 231-240. , Jul; Pei, J., Hong, P., Pan, M., Liu, J., Zhou, J., Optimal VNF placement via deep reinforcement learning in SDN/NFV-enabled networks (2020) Ieee J. Sel. Areas Commun., 38 (2), pp. 263-278. , Feb; Gu, L., Zeng, D., Li, W., Guo, S., Zomaya, A.Y., Jin, H., Intelligent VNF orchestration and flow scheduling via model-Assisted deep reinforcement learning (2020) Ieee J. Sel. Areas Commun., 38 (2)