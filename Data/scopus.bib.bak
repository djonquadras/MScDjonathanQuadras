}

@ARTICLE{Bakhouya201061,
author={Bakhouya, M. and Gaber, J.},
title={A query routing approach based on users' satisfaction for resource discovery in service-oriented networks},
journal={World Wide Web},
year={2010},
volume={13},
number={1-2},
pages={61-73},
doi={10.1007/s11280-009-0079-z},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-78751577585&doi=10.1007%2fs11280-009-0079-z&partnerID=40&md5=ff5a3f99a5a2b548522ffa109fb4c20f},
affiliation={Université de Technologies de Belfort-Montbéliard, Rue Thierry Mieg, 90010 Belfort Cedex, France},
abstract={Service oriented networks are distributed computing infrastructures that provide widely distributed resources. These networks are dynamic and their size and complexity continue to increase and allow to users a ubiquitous access to available resources and services. Therefore, efficient query routing approaches in large and highly distributed service oriented networks are required and need to be adaptive in order to cope with a dynamically changing environment. In this paper, a query routing approach based on mobile agents and random walks with a reinforcement learning technique is presented. By enhancing random walks with a reinforcement learning mechanism centered on users' satisfaction, this approach allows dynamic and self-adaptive location of required resources. Peers incorporate knowledge from past and present queries which will be used during next searches by mobile agents to select their next hops. This approach is analyzed through two query routing techniques using the network simulator ns2. © Springer Science+Business Media, LLC 2009.},
author_keywords={Mobile agents;  Query routing;  Random walks;  Reinforcement learning mechanisms;  Resource discovery;  Service oriented networks;  Users'satisfaction},
keywords={Query routing;  Random Walk;  Resource discovery;  Service oriented network;  Users'satisfaction, Dynamics;  Mobile agents;  Random processes;  Reinforcement learning;  Wireless networks, Distributed computer systems},
references={Amin, K.A., Mikler, A.R., (2002) Dynamic Agent Population In Agent-based Distance Vector Routing, Second International Workshop On Intelligent Systems Design and Applications, p. 195. , Atlanta, USA, ISBN:0-9640398-0-X, August; Baala, H., Flauzac, O., Gaber, J., Buid, M., El-Ghazawi, T., A self-stabilizing distributed algorithm for spanning tree construction in wireless ad hoc networks (2003) J. Parallel Distrib. Comput, 63 (1), pp. 97-104; Bakhouya, M., Gaber, J., (2006) Adaptive Approach For the Regulation of a Mobile Agent Population In a Distributed Network. In: 5th International Symposium On Parallel and Distributed Computing (ISPDC'06), pp. 360-366. , IEEE Press; Bakhouya, M., Gaber, J., (2006) Model-driven Walks For Resource Discovery In Peer-to-peer. International Conference On Intelligent Agents, Web Technologies and Internet Commerce-(IAWTIC'2006, and CIMCA'06, p. 240. , IEEE Press; Bakhouya, M., Gaber, J., Service composition approaches for ubiquitous and pervasive computing environments: A survey (2007) Agent Systems In Electronic Business, Pp. 323-, p. 409. , In: Li, E.Y., Yuan, S.-T. (eds.), Information Science Reference/IGI Publishing, Hershey, Pennsylvania, USA; Bakhouya, M., Gaber, J., Approaches for ubiquitous computing (2008) Wireless Ad Hoc and Sensor Networks, pp. 111-142. , In: Labiod, H. (ed.), ISTE Publishing Knowledge/John Wiley and Sons Inc., London, UK; Bettini, C., Maggiorini, D., Riboni, D., Distributed context monitoring for the adaptation of continuous services (2007) World Wide Web, 10 (4), pp. 503-528; Bianchini, D., de Antonellis, V., Melchiori, M., Flexible semantic-based service matchmaking and discovery (2008) World Wide Web, 11 (2), pp. 227-251; http://www.cs.bu.edu/brite/, BRITE generator, available at the Computer Sciences Department of Boston University web site; Broder, A.Z., Karlin, A.R., Raghavann, P., Upfal, E., Trading space for time in undirected s-t connectivity (1989) Proceedings of 21st ACM Symposium On T