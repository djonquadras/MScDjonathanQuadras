@ARTICLE{Skałkowski201361,
author={Skałkowski, K. and Zieliński, K.},
title={Automatic adaptation of SOA systems supported by machine learning},
journal={IFIP Advances in Information and Communication Technology},
year={2013},
volume={394},
pages={61-68},
doi={10.1007/978-3-642-37291-9_7},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84928236120&doi=10.1007%2f978-3-642-37291-9_7&partnerID=40&md5=838a8bbd5199090c8d9aae8bce9f8212},
affiliation={AGH University of Science and Technology, Department of Computer Science, al. Mickiewicza 30, Kraków, 30-059, Poland},
abstract={Recent advances in the development of information systems have led to increased complexity and cost in terms of the required maintenance and management. On the other hand, systems built in accordance with modern architectural paradigms, such as Service Oriented Architecture (SOA), posses features enabling extensive adaptation, not present in traditional systems. Automatic adaptation mechanisms can be used to facilitate system management. The goal of this work is to show that automatic adaptation can be effectively implemented in SOA systems using machine learning algorithms. The presented concept relies on a combination of clustering and reinforcement learning algorithms. The paper discusses assumptions which are necessary to apply machine learning algorithms to automatic adaptation of SOA systems, and presents a machine learning-based management framework prototype. Possible benefits and disadvantages of the presented approach are discussed and the approach itself is validated with a representative case study. © IFIP International Federation for Information Processing 2013.},
author_keywords={Adaptive manager;  Machine learning;  SOA},
keywords={Clustering algorithms;  Information management;  Information services;  Learning systems;  Machine learning;  Reinforcement learning;  Service oriented architecture (SOA), Automatic adaptation;  Management frameworks;  Representative case;  System management;  Traditional systems, Learning algorithms},
references={Arsanjani, A., Zhang, L.-J., Ellis, M., Allam, A., Channabasavaiah, K., S3: A Service-Oriented Reference Architecture (2007) IT Professional, 9 (3), pp. 10-17; Atzori, L., Iera, A., Morabito, G., The Internet of Things: A survey (2010) The International Journal of Computer and Telecommunications Networking, 54 (15), pp. 2787-2805; Zieliński, K., Szydło, T., Szymacha, R., Kosiiski, J., Kosińska, J., Jarz^b, M.: Adaptive SOA Solution Stack (2012) IEEE Transactions on Services Computing, 5 (2), pp. 149-163; André, F., Daubert, E., Gauvrit, G., Towards a Generic Context-Aware Framework for Self-Adaptation of Service-Oriented Architectures (2010) 2010 Fifth International Conference on Internet and Web Applications and Services, pp. 309-314. , ICIW; Kephart, J.O., Chess, D.M., The vision of autonomic computing (2003) Computer, 36 (1), pp. 41-50; Stokic, D., Scholze, S., Barata, J., Self-learning embedded services for integration of complex, flexible production systems (2011) IECON 2011 - 37Th Annual Conference on IEEE Industrial Electronics Society, pp. 415-420. , November 7-10, ISSN: 1553-572X; Al-Masri, E., Mahmoud, Q.H., Discovering the best web service: A neural network-based solution (2009) IEEE International Conference on Systems, Man and Cybernetics, pp. 4250-4255. , SMC 2009, October 11-14; Mohanty, R., Ravi, V., Patra, M.R., Web-services classification using intelligent technique (2010) Expert Systems with Applications, 37 (7), pp. 5484-5490. , ISSN 0957-4174; Challagulla, V., A Machine Learning-Based Reliability Assessment Model for Critical Software Systems (2007) 31St Annual International Computer Software and Applications Conference, 1, pp. 79-86. , COMPSAC 2007, July 24-27; OSGi Service Platform Core Specification (2007) Release, 4, p. 1. , http://www.osgi.org/Specifications, The OSGi Alliance; Mcwilliams, B., Montana, G., Predictive Subspace Clustering (2011) 2011 10Th International Conference on Machine Learning and Applications and Workshops (