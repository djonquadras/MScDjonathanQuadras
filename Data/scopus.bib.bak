@CONFERENCE{Jureta20071245,
author={Jureta, I.J. and Faulkner, S. and Achbany, Y. and Saerens, M.},
title={Dynamic task allocation within an open service-oriented MAS architecture},
journal={Proceedings of the International Conference on Autonomous Agents},
year={2007},
pages={1245-1247},
doi={10.1145/1329125.1329375},
art_number={206},
note={cited By ; Conference of 6th International Joint Conference on Autonomous Agents and Multiagent Systems, AAMAS'07 ; Conference Date: 14 May 2008 Through 18 May 2008;  Conference Code:75310},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-60449084688&doi=10.1145%2f1329125.1329375&partnerID=40&md5=f1a8a5a8afa7325da61ced5de3fefe4a},
affiliation={Information Management Research Unit (IMRU), University of Namur, Belgium; Information Systems Research Unit (ISYS), Universite de Louvain, Belgium},
abstract={A MAS architecture consisting of service centers is proposed. Within each service center, a mediator coordinates service delivery by allocating individual tasks to corresponding task specialist agents depending on their prior performance while anticipating performance of newly entering agents. By basing mediator behavior on a novel multicriteria-driven (including quality of service, deadline, reputation, cost, and user preferences) reinforcement learning algorithm, integrating the exploitation of acquired knowledge with optimal, undirected, continual exploration, adaptability to changes in agent availability and performance is ensured. The reported experiments indicate the algorithm behaves as expected and outperforms two standard approaches. © 2007 IFAAMAS.},
author_keywords={Agent architectures;  Mediation;  Multiagent systems;  Reinforcement learning;  Task allocation},
keywords={Agent architectures;  Dynamic task allocations;  MAS architectures;  Mediation;  Multi criterion;  Multiagent systems;  Open services;  Reinforcement learning algorithms;  Service centers;  Service deliveries;  Task allocation, Agents;  Fuzzy clustering;  Learning algorithms;  Quality of service;  Reinforcement;  Reinforcement learning, Autonomous agents},
references={Achbany, Y., Fouss, F., Yen, L., Pirotte, A., Saerens, M., Tuning continual exploration in reinforcement learning (2005), p. 1. , Technical report; Bather, J., (2000) Decision Theory, , Wiley; Bersekas, D.P., (2000) Dynamic Programming and Optimal Control, , Athena Scientific; Christofides, N., (1975) Graph theory: An algorithmic approach, , Academic Press; Achbany, Y., Fouss, F., Yen, L., Pirotte, A., Saerens, M., Optimal Tuning of Continual Online Exploration in Reinforcement Learning (2006) Proc. ICANN},
correspondence_address1={Jureta, I. J.; Information Management Research Unit (IMRU), Belgium; email: iju@info.fundp.ac.be},
address={Honolulu, HI},
isbn={9788190426275},
language={English},
abbrev_source_title={Proc Int Conf Autonom Agents},
document_type={Conference Paper},
source={Scopus},
}

@CONFERENCE{Jureta2007304,
author={Jureta, I.J. and Faulkner, S. and Achbany, Y. and Saerens, M.},
title={Dynamic web service composition within a service-oriented architecture},
journal={Proceedings - 2007 IEEE International Conference on Web Services, ICWS 2007},
year={2007},
pages={304-311},
doi={10.1109/ICWS.2007.79},
art_number={4279613},
note={cited By ; Conference of 2007 IEEE International Conference on Web Services, ICWS 2007 ; Conference Date: 9 July 2007 Through 13 July 2007;  Conference Code:72551},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-46849091791&doi=10.1109%2fICWS.2007.79&partnerID=40&md5=00c2c63e86090417d0ddfee4e3036c08},
affiliation={Info. Manag. Research Unit (IMRU), University of Namur, Belgium; Info. Syst. Research Unit (ISYS), Université de Louvain, Belgium},
abstract={Increasing automation requires open, distributed, service-oriented systems capable of multicriteria-driven, dynamic adaptation for appropriate response to changing operating conditions. We combine a simple architecture with a novel algorithm to enable openness, distribution, and multi-criteria-driven service composition at runtime. The service-oriented architecture involves mediator web services coordinating other web services into compositions necessary to fulfil user requests. By basing mediator services ' behavior on a novel multicriteria-driven (including quality of service, deadline, reputation, cost, and user preferences) reinforcement learning algorithm, which integrates the exploitation of acquired knowledge with optimal, undirected, continual exploration, we ensure that the system is responsive to changes in the availability of web services. The reported experiments indicate the algorithm behaves as expected and outperforms two standard approaches. © 2007 IEEE.},
keywords={Architectural design;  Boolean functions;  Chemical analysis;  Dynamic response;  Information services;  Learning algorithms;  Learning systems;  Reinforcement;  Reinforcement learning;  Standards;  Structure (composition);  Web services;  World Wide Web, Dynamic adaptations;  international conferences;  Multi-criteria;  Novel algorithms;  Operating conditions;  Reinforcement Learning algorithms;  Run time;  Service compositions;  Service oriented architecture (SOA);  Service-oriented;  User preferences;  Web service composition, Quality of service},
references={Abdallah, S., Lesser, V., Modeling Task Allocation Using a Decision Theoretic Model (2005) Proc. Int. Conf. Auton. Agents and Multi-Agent Syst; Abdallah, S., Lesser, V., Learning the Task Allocation Game (2006) Proc. Int. Conf. Auton. Agents and Multi-Agent Syst; Achbany, Y., Fouss, F., Yen, L., Pirotte, A., Saerens, M., Tuning continual exploration in reinforcement learning (2005), p. 3. , Technical report<sup/>; Bather, J., (2000) Decision Theory: An Introduction to Dynamic Programming and Sequential Decisions, , Wiley; Benatallah, B., Hacid, M.-S., Leger, A., Rey, C., Toumani, F., On automating Web services discovery (2005) VLDB Jurnal, 14; Bersekas, D.P., (2000) Dynamic Programming and Optimal Control, , Athena Scientific; (2001) VLDB Journal, 10 (1). , F. Casati, M.-C. Shan, D. Georgakopoulos Eds; Christofides, N., (1975) Graph theory: An algorithmic approach, , Academic Press; Cover, T.M., Thomas, J.A., (1991) Elements of Information Theory, , John Wiley and Sons; DAML-S: Web service description for the Semantic Web (2002) Proc. Int. Semantic Web Conf, 348-363. , DAML Services Coalition; Shaheen Fatima, S., Wooldridge, M., Adaptive Task and Resource Allocation in Multi-Agent Systems (2001) Proc. Int. Conf. Auton. Agents; Foundation for Intelligent Physical Agents. FIPA Quality of Service Ontology Specification. Doc.No. SC00094A. 2002; Hannah, H., Mouaddib, A.-I., Task selection problem under uncertainty as decision-making (2002) Proc. Int. Conf. Auton. Agents and Multi-Agent Syst; Jennings, N.R., On Agent-Based Software Engineering (2000) Artificial Intelligence, 117, pp. 277-296; Kapur, J.N., Kesavan, H.K., (1992) Entropy optimization principles with applications, , Academic Press; Klein, F., Tichy, M., Building Reliable Systems based on Self-Organizing Multi-Agent Systems (2006) Proc. Int. Worksh. Softw. Eng. Large Multi-Agent Syst, pp. 51-57; Maximilien, E.M., Singh, M.P., Multiagent System for Dynamic Web Services Selection (2005) Proc. Int. Conf. Auton. Agents and Multi-Agent Syst; Mitchell, T.M., (1997) Machine learning, , McGraw-Hill; Rohanimanesh, K., Mahadevan, S., Learning to take concurrent actions (2003) Proc. Int. Conf. on Neural Info. Proc. Syst; Achbany, Y., Fouss, F., Yen, L., Pirotte, A., Saerens, M., Optimal Tuning of Continual Online Exploration in Reinforcement Learning (2006) Proc. Int. Conf. Artif. Neural Netw; Smith, R.G., The contract net protocol: High level communication and control in a distributed problem solver (1980) IEEE Trans. Computers, 29 (12), pp. 1104-1113; Sutton, R.S., Barto, A.G., (1998) Reinforcement Learning: An Introduction, , MIT Press; Sutton, R.S., Precup, D., Singh, S.P., Between MDPs and semi-MDPs: A framework for temporal abstraction in reinforcement learning (1999) Artificial Intelligence, 112 (1-2); Tennenhouse, D., Proactive Computing (2000) Comm. ACM, 42 (5); Tesauro, G., Chess, D.M., Walsh, W.E., Das, R., Segal, A., Whalley, I., Kephart, J.O., White, S.R., A Multi-Agent Systems Approach to Autonomic Computing (2004) Proc. Int. Conf Auton. Agents and Multi-Agent Syst, pp. 464-471; Vincke, P., (1992) Multicriteria Decision-Aid, , Wiley; Zacharia, G., Maes, P., Trust Management Through Reputation Mechanisms (2000) Applied Artificial Intelligence, 14},
