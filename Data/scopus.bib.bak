@CONFERENCE{Razo-Zapata2013,
author={Razo-Zapata, I.S. and Castanon, G. and Mex-Perera, C.},
title={Lightpath requests processing in flexible packet switching optical networks using reinforcement learning},
journal={International Conference on Transparent Optical Networks},
year={2013},
doi={10.1109/ICTON.2013.6602872},
art_number={6602872},
note={cited By ; Conference of 2013 15th International Conference on Transparent Optical Networks, ICTON 2013 ; Conference Date: 23 June 2013 Through 27 June 2013;  Conference Code:99855},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84885229438&doi=10.1109%2fICTON.2013.6602872&partnerID=40&md5=599b76f91889fefd5f824387018d3f2c},
affiliation={Department of Electrical and Computer Engineering, Tecnologico de Monterrey, Campus Monterrey, Av. Eugenio Garza Sada 2501 Sur, Col. Tecnologico, Monterrey, N.L., Mexico},
abstract={We present a self-adaptive framework to process lightpath requests on a packet switching optical network. Our framework takes care of issues regarding lightpath setting up, resource reservation and load balancing. The framework is composed of a dimensioning phase that adds up new resources to an initial topology and a learning phase that provides routing intelligence to efficiently use the dimensioned resources. The proposed framework is tested on a realistic topology achieving a probability of packet loss of 1×10-4. © 2013 IEEE.},
author_keywords={dimensioning;  learning;  lightpath requests;  packet loss;  service-oriented optical networks},
keywords={dimensioning;  learning;  Learning phase;  Lightpaths;  Resource reservations;  Service Oriented, Packet loss;  Reinforcement learning;  Topology;  Transparent optical networks, Packet switching},
references={Maglio, P.P., Kieliszewski, C.A., Spohrer, J.C., Handbook of service science service science (2010) Research and Innovations in the Service Economy, , Springer; De Leenheer, M., Thysebaert, P., Volckaert, B., De Turck, F., Dhoedt, B., Demeester, P., Simeonidou, D., Omahony, M.J., A view on enabling-consumer oriented grids through optical burst switching (2006) Comm. Mag., 44, pp. 124-131. , March; Zervas, G., Martini, V., Qin, Y., Escalona, E., Nejabati, R., Simeonidou, D., Baroncelli, F., Castoldi, P., Service-oriented multigranular optical network architecture for clouds (2010) IEEE/OSA Journal of Optical Communications and Networking, 2, pp. 883-891. , Oct; Callegati, F., Campi, A., Cerroni, W., Automated transport service management in the future internet Concepts and operations (2011) Journal of Internet Services and Applications, 2, pp. 69-79; Simeonidou, D., Nejabati, R., Zervas, G., Klonidis, D., Tzanakaki, A., Omahony, M., Dynamic optical-network architectures and technologies for existing and emerging grid services (2005) Journal of Lightwave Technology, 23, pp. 3347-3357. , Oct; Mell, P., Grance, T., (2009) The NIST Definition of Cloud Computing, , tech. rep., Jul; Callegati, F., Cerroni, W., Campi, A., Application scenarios for cognitive transport service in next-generation networks (2012) Comm. Mag., 50, pp. 62-69. , Mar; Castañon, G., Tancevski, L., Tamil, L., Optical packet switching with multiple path routing (2000) Journal of Computer Networks and ISDN Systems, Special Issue on Optical Networks for New Generation Internet and Data Communication Systems, 32, pp. 653-662; Razo-Zapata, I.S., Castañon, G., Mex-Perera, C., On self-healing for transparent optical packet switching networks An approach to security (2011) Proc. 15th International Conference on Optical Network Design and Modeling (ONDM), pp. 1-6. , Feb; Yangand, H., Yoo, S.J.B., All-optical variable buffering strategies and switch fabric architectures for future all-optical data routers (2005) Journal of Lightwave Technology, 23 (10), pp. 3321-3330},
