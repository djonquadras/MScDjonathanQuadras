@CONFERENCE{Herber2021,
author={Herber, P. and Adelt, J. and Liebrenz, T.},
title={Formal verification of intelligent cyber-physical systems with the interactive theorem prover keymaera X},
journal={CEUR Workshop Proceedings},
year={2021},
volume={2814},
note={cited By ; Conference of 2021 Workshops and Tools Demonstrations of the Software Engineering Satellite Events, SE-SE 2021 ; Conference Date: 22 February 2021 Through 26 February 2021;  Conference Code:167112},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85101638253&partnerID=40&md5=ecca7587fdd3be32ed778ba839831844},
affiliation={University of Münster, Computer Science Department, Embedded Systems Group, Einsteinstr. 62, Münster, 48149, Germany},
abstract={Cyber-physical systems are increasingly used in dynamic environments, and have to make safety-critical decisions autonomously. Machine learning is a powerful technique to make such decisions. For example, reinforcement learning can be used to learn controllers that outperform manually designed controllers in highly dynamic or uncertain environments. However, the learning process and the resulting controllers often impede system verification, as their behavior is hard to predict. To formally guarantee safety properties, a formal description is required, which is often not available in industrial design processes and hard to obtain for unpredictable machine learning components. In this paper, we briefly discuss our current work on the semi-automatic deductive verification of intelligent cyber-physical systems. To support industrial design processes, we target the widely used modeling language Simulink together with its Reinforcement Learning Toolbox. To support deductive formal verification, we propose to use and extend our existing framework for the service-oriented verification of hybrid systems that are modeled in Simulink. The framework enables the automated transformation of Simulink models or services into differential dynamic logic and formal verification with the interactive theorem prover KeYmaera X. Copyright © 2021 for this paper by its authors.},
author_keywords={Cyber-physical systems;  Formal verification;  Reinforcement learning},
keywords={Accident prevention;  Controllers;  Cyber Physical System;  Dynamics;  Embedded systems;  Formal verification;  Hybrid systems;  Modeling languages;  Process control;  Product design;  Reinforcement learning;  Theorem proving, Automated transformations;  Deductive verification;  Differential dynamic logic;  Dynamic environments;  Interactive theorem prover;  System verifications;  Uncertain environments;  Verification of hybrid systems, Learning systems},
references={Araiza-Illan, Dejanira, Eder, Kerstin, Richards, Arthur, Formal verification of control systems’ properties with theorem proving (2014) UKACC Int. Conference on Control (CONTROL). IEEE, pp. 244-249. , [AIER14]; Alshiekh, Mohammed, Bloem, Roderick, Ehlers, Rüdiger, Könighofer, Bettina, Niekum, Scott, Topcu, Ufuk, (2017) Safe Reinforcement Learning via Shielding, , [Al17] arXiv preprint arXiv:1708.08611; Fulton, Nathan, Platzer, André, Safe Reinforcement Learning via Formal Methods: Toward Safe Control Through Proof and Learning (2018) The Thirty-Second AAAI Conference on Artificial Intelligence (AAAI-18), 32 (1), pp. 6485-6492. , [FP18] 02; Fulton, Nathan, Mitsch, Stefan, Quesel, Jan-David, Völp, Marcus, Platzer, André, KeYmaera X: An Axiomatic Tactical Theorem Prover for Hybrid Systems (2015) International Conference on Automated Deduction, pp. 527-538. , [Fu15] Springer; Herdt, Vladimir, Le, Hoang M, Grosse, Daniel, Drechsler, Rolf, Verifying SystemC using intermediate verification language and stateful symbolic simulation (2018) IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems, 38 (7), pp. 1359-1372. , [He18]; Herber, Paula, Pockrandt, Marcel, Glesner, Sabine, STATE – a SystemC to Timed Automata Transformation Engine (2015) ICESS. IEEE, , [HPG15]; Herber, Paula, Reicherdt, Robert, Bittner, Patrick, Bit-precise formal verification of discrete-time MATLAB/Simulink models using SMT solving (2013) Int. Conference on Embedded Software (EMSOFT). IEEE, pp. 1-10. , [HRB13]; (2011) IEEE Std. 1666–2011, Open SystemC Language Reference Manual, , [IE11] IEEE Standards Association:, IEEE Press; Liebrenz, Timm, Herber, Paula, Glesner, Sabine, Deductive Verification of Hybrid Control Systems Modeled in Simulink with KeYmaera X (2018) International Conference on Formal Engineering Methods, pp. 89-105. , [LHG18] Springer; Liebrenz, Timm, Herber, Paula, Glesner, Sabine, A Service-Oriented Approach for Decomposing and Verifying Hybrid System Models (2019) International Conference on Formal Aspects of Component Software, pp. 127-146. , [LHG19] Springer; Minopoli, Stefano, Frehse, Goran, SL2SX translator: from Simulink to SpaceEx models (2016) Int. Conf. on Hybrid Systems: Computation and Control, pp. 93-98. , [MF16] ACM; (2021), www.mathworks.com/products/simulink.html, [Th21] The MathWorks:, Simulink},
