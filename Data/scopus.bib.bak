@CONFERENCE{Wang2020884,
author={Wang, Q. and Shu, J. and Yao, X. and Liu, L.},
title={A High-performance IoT Middleware Based on Reinforcement Learning},
journal={2020 IEEE 6th International Conference on Computer and Communications, ICCC 2020},
year={2020},
pages={884-890},
doi={10.1109/ICCC51575.2020.9345234},
art_number={9345234},
note={cited By ; Conference of 6th IEEE International Conference on Computer and Communications, ICCC 2020 ; Conference Date: 11 December 2020 Through 14 December 2020;  Conference Code:167151},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85101723846&doi=10.1109%2fICCC51575.2020.9345234&partnerID=40&md5=234a71fa3d5d60385fb91d3983d1d242},
affiliation={School of Software, Nanchang Hangkong University, Jiangxi, China},
abstract={This paper proposes a high-performance Internet of Things (IoT) middleware based on reinforcement learning. The adaptive decision-maker is realized by the K-armed bandit algorithm, which can dynamically resize the server accept queue. This paper adopts service-oriented architecture(SOA) to make the middleware architecture be loosely-coupled, reusable, and easily extensible. Through standardized service interfaces, users can transparently interact with heterogeneous IoT devices. In addition, the high availability of the middleware platform is achieved through non-blocking IO, caching, and message queuing technologies. Through the experiments over Apache JMeter, the results verify that our IoT middleware has a better performance under high concurrency scenarios. © 2020 IEEE.},
author_keywords={IoT;  middleware;  reinforcement learning;  wireless sensor network},
keywords={Decision making;  Information services;  Middleware;  Reinforcement learning;  Service oriented architecture (SOA), Decision makers;  High availability;  High concurrencies;  Internet of Things (IOT);  Loosely coupled;  Middleware architecture;  Middleware platforms;  Service interfaces, Internet of things},
