@CONFERENCE{Moghaddam2019194,
author={Moghaddam, M. and Jones, A. and Wuest, T.},
title={Design of marketplaces for smart manufacturing services},
journal={Procedia Manufacturing},
year={2019},
volume={39},
pages={194-201},
doi={10.1016/j.promfg.2020.01.312},
note={cited By ; Conference of 25th International Conference on Production Research Manufacturing Innovation: Cyber Physical Manufacturing, ICPR 2019 ; Conference Date: 9 August 2019 Through 14 August 2019;  Conference Code:158666},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85082746889&doi=10.1016%2fj.promfg.2020.01.312&partnerID=40&md5=66ae032d57832564f5de539b3a136097},
affiliation={Department of Mechanical and Industrial Engineering, Northeastern University, 360 Huntington Avenue, Boston, MA  02115, United States; National Institute of Standards and Technology, 100 Bureau Dr, Gaithersburg, MD  20899, United States; Department of Industrial and Management Systems Engineering, West Virginia University, Morgantown, WV  26506, United States},
abstract={The future of manufacturing depends on the successful implementation of two terms: cyber-physical systems (CPS) and micro-services. CPS technologies are transforming the way manufacturing components interact, just as the Internet has transformed the interaction with information. A micro-service is an architectural style that structures an application as a collection of loosely-coupled, independent, and self-executable programs that can be composed to provide various capabilities of large, monolithic manufacturing applications such as ERP and MES. The transition to such a modular structure enables two important features. First, micro-services can be sourced on a pay-as-you-go fashion from a large, diverse, and growing number of independent providers, thus opening the manufacturing space to new players such as innovative and agile startups. Second, those micro-services can be viewed as building-blocks for creating on-demand, complex, custom processes that address the specific needs of users. Taken together, micro-services, the platforms on which they reside, and service vendors constitute a multi-platform marketplace. This article first provides an overview of new manufacturing paradigms enabled by CPS and micro-services. It then formalizes the multi-platform marketplaces for micro-services as multi-layer networks of collaborating-competing agents with different interests, policies, capabilities, and technologies. It finally formulates a research methodology for optimizing the policies and interactions through the theories of matching markets and multi-agent reinforcement learning. © 2019 The Authors. Published by Elsevier Ltd.},
author_keywords={Cyber-physical systems;  Industry 4.0;  Matching markets;  Multi-agent reinforcement learning;  Service-oriented manufacturing},
references={Gartner, (2018) Gartner Forecasts Worldwide Public Cloud Revenue to Grow 21.4 Percent in 2018, , Online. Available: Gartner Forecasts Worldwide Public Cloud Revenue to Grow 21.4 Percent in 2018; Differences in Cloud Adoption across Global Industries, , TCS Online. Available: Differences in Cloud Adoption Across Global Industries; Ivezic, N., Kulvatunyou, B., Brandl, D., Cho, H., Lu, Y., Noller, D., Davis, J., Bernstein, W., (2017) NIST Advanced Manufacturing Series 100-8 NIST / OAGi Workshop: Drilling down on Smart Manufacturing - Enabling Composable Apps, p. 39; Ivezic, N., Kulvatunyou, B., Brandl, D., Cho, H., Lu, Y., Noller, D., Davis, J., Bernstein, W., (2017) NIST Advanced Manufacturing Series 100-8 - 2016 NIST / OAGi Workshop: Drilling down on Smart Manufacturing - Enabling Composable Apps; Clean Energy Smart Manufacturing Innovation Institute, , Online. Available: cesmii.org; Ivezic, N., Brandl, D., Witherell, P., Lu, Y., (2017) 2017 NIST / OAGi Workshop: Enabling Composable Service-Oriented Manufacturing Systems; Moghaddam, M., Cadavid, M., Kenley, C.R., Deshmukh, A., Reference architectures for smart manufacturing: A critical review (2018) J. Manuf. Syst., 49, pp. 215-225; Giovanoli, C., Pulikal, P., Grivas, S.G., E-marketplace for cloud services (2014) The Fifth International Conference on Cloud Computing, GRIDs, and Virtualization, (c), pp. 76-83; Banerjee, A.G., Beckmann, B., Carbone, J., Derose, L., Koudal, P., Mackenzie, P., Salvo, J., Yund, W., Cloud computing-based marketplace for collaborative design and manufacturing (2016) IoT 360, 169, pp. 409-418. , A. G. B, B. M. et Al., Ed. ICST Institute for Computer Sciences, Social Informatics and Telecommunications Engineering; Ren, L., Zhang, L., Tao, F., Zhao, C., Chai, X., Zhao, X., Cloud manufacturing: From concept to practice (2015) Enterp. Inf. Syst., 9 (2), pp. 186-209; Moghaddam, M., Nof, S.Y., The collaborative factory of the future (2017) Int. J. Comput. Integr. Manuf., 30 (1), pp. 23-43; Hofmann, E., Rüsch, M., Industry 4.0 and the current status as well as future prospects on logistics (2017) Comput. Ind., 89, pp. 23-34; Monostori, L., Kádár, B., Bauernhansl, T., Kondoh, S., Kumara, S., Reinhart, G., Sauer, O., Ueda, K., Cyber-physical systems in manufacturing (2016) CIRP Ann. - Manuf. Technol., 65 (2), pp. 621-641; Lu, Y., Morris, K.C., Frechette, S., (2016) Current Standards Landscape for Smart Manufacturing Systems, 8107. , April; Radziwon, A., Bilberg, A., Bogers, M., Madsen, E.S., The smart factory: Exploring adaptive and flexible manufacturing solutions (2014) Procedia Eng, 69, pp. 1184-1190. , Jan; Wang, L., Torngren, M., Onori, M., Current status and advancement of cyber-physical systems in manufacturing (2015) J. Manuf. Syst., 37, pp. 517-527; Lee, J., Bagheri, B., Jin, C., Introduction to cyber manufacturing (2016) Manuf. Lett., 8, pp. 11-15; (2016) DIN SPEC 91345:2016-04, Reference Architecture Model Industrie 4.0 (RAMI4.0), , DIN Berlin; Xu, X., From cloud computing to cloud manufacturing (2012) Robot. Comput. Integr. Manuf., 28 (1), pp. 75-86. , Feb; Wu, D., Rosen, D.W., Wang, L., Schaefer, D., Cloud-based design and manufacturing: A new paradigm in digital manufacturing and design innovation (2015) CAD Comput. Aided Des., 59, pp. 1-14; Jiang, P., Ding, K., Leng, J., Towards a cyber-physical-social-connected and service-oriented manufacturing paradigm: Social manufacturing (2016) Manuf. Lett., 7, pp. 15-21; Moghaddam, M., Kenley, C.R., Colby, J.M., Berns, M.N.C., Rausch, R., Markham, J., Skeffington, W.M., Deshmukh, A.V., Next-generation enterprise architectures: Common vernacular and evolution towards service-orientation (2017) 2017 IEEE 15th International Conference on Industrial Informatics (INDIN), pp. 32-37; Lu, Y., Riddick, F., Ivezic, N., (2016) The Paradigm Shift in Smart Manufacturing System Architecture, pp. 767-776. , Springer, Cham; (2016) ISO/IEC 18384: 2016, Information Technology - Reference Architecture for Service Oriented Architecture (SOA RA); Davis, J., Edgar, T., Graybill, R., Korambath, P., Schott, B., Swink, D., Wang, J., Wetzel, J., Smart manufacturing (2015) Annu. Rev. Chem. Biomol. Eng., 6 (1), pp. 141-160. , Jul; Amazon Web Services, , https://aws.amazon.com, Online; Microsoft Azure, , https://azure.microsoft.com/en-us/, Online; Cisneros-Cabrera, S., Ramzan, A., Sampaio, P., Mehandjiev, N., Digital Marketplaces for Industry 4.0: A survey and gap analysis (2017) PRO-VE 2017: Collaboration in a Data-Rich World, pp. 18-27; Moghaddam, M., Nof, S.Y., (2017) Dynamic and Distributed Matching, pp. 125-165; Niederle, M., Roth, A.E., Tayfun, S., Matching (2007) The New Palgrave Dictionary of Economics, pp. 1-17. , Palgrave Macmillan; Roth, A.E., (2015) Who Gets What-and Why: The New Economics of Matchmaking and Market Design, , Eamon Dolan/Houghton Mifflin Harcourt; Roth, A.E., Sotomayor, M.A.O., (1990) Two-Sided Matching: A Study in Game-Theoretic Modeling and Analysis, , Cambridge University Press; Gale, D., Shapley, L.S., College admissions and the stability of marriage (1962) Am. Math. Mon., 69 (1), pp. 9-15; Lichtman, J.D., (2015) On the Multidimensional Stable Marriage Problem, pp. 1-8; Surana, A., Kumara, S., Greaves, M., Raghavan, U.N., (2005) Supply-Chain Networks: A Complex Adaptive Systems Perspective, 43 (20); Moghaddam, M., Nof, S.Y., Collaborative service-component integration in cloud manufacturing (2018) Int. J. Prod. Res., 56 (1-2), pp. 677-691; Choi, T.Y., Dooley, K.J., Rungtusanatham, M., Supply networks and complex adaptive systems: Control versus emergence (2001) J. Oper. Manag., 19 (3), pp. 351-366; Busoniu, L., Babuska, R., de Schutter, B., A comprehensive survey of multiagent reinforcement learning (2008) IEEE Trans. Syst. Man, Cybern. Part C Appl. Rev., 38 (2), pp. 156-172; Mnih, V., Kavukcuoglu, K., Silver, D., Rusu, A.A., Veness, J., Bellemare, M.G., Graves, A., Hassabis, D., Human-level control through deep reinforcement learning (2015) Nature, 51