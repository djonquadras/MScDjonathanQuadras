@CONFERENCE{Liu20191775,
author={Liu, Y. and Zhang, L. and Wang, L. and Xiao, Y. and Xu, X. and Wang, M.},
title={A framework for scheduling in cloud manufacturing with deep reinforcement learning},
journal={IEEE International Conference on Industrial Informatics (INDIN)},
year={2019},
volume={2019-July},
pages={1775-1780},
doi={10.1109/INDIN41052.2019.8972157},
art_number={8972157},
note={cited By ; Conference of 17th IEEE International Conference on Industrial Informatics, INDIN 2019 ; Conference Date: 22 July 2019 Through 25 July 2019;  Conference Code:157260},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85079069466&doi=10.1109%2fINDIN41052.2019.8972157&partnerID=40&md5=c7cfc1b3291cd10866ce40bb1215c93d},
affiliation={Center for Smart Manufacturing Systems, School of Mechano-Electronic Engineering, Xidian University, Xi'an, China; School of Automation Science and Electrical Engineering, Beihang University, Beijing, China; Department of Production Engineering, KTH Royal Institute of Technology, Stockholm, Sweden; Beijing Institute of Electronic System Engineering, State Key Laboratory of Intelligent, Manufacturing System Technology, Beijing, China; Department of Mechanical Engineering, University of Auckland, Auckland, New Zealand},
abstract={Cloud manufacturing is a novel service-oriented networked manufacturing paradigm that aims to provide on-demand manufacturing cloud services to consumers. Scheduling is a critical means for achieving that aim. Currently, research on scheduling in cloud manufacturing is still in its infancy, and current frequently adopted meta-heuristic algorithm-based approaches have some shortcomings, e.g. they require complex design processes and lack adaptability to dynamic environments. Deep reinforcement learning (DRL) that combines advantages of reinforcement learning and deep learning provides an efficient, adaptive and intelligent approach for solving scheduling problems in cloud manufacturing. However, to the best of our knowledge, there has been no application of DRL to scheduling in cloud manufacturing. This work conducts a preliminary exploration over this issue. First, a DRL-based framework for scheduling in cloud manufacturing is proposed. Then a DRL model for online single-task scheduling in cloud manufacturing is presented to demonstrate the effectiveness of the framework. DRL as a promising technique will find wide applications in cloud manufacturing, and this work can provide some reference for future research on this. © 2019 IEEE.},
author_keywords={Cloud manufacturing;  Deep reinforcement learning;  Scheduling},
keywords={Computer aided manufacturing;  Engineering education;  Heuristic algorithms;  Industrial informatics;  Industrial research;  Machine learning;  Manufacture;  Reinforcement learning;  Scheduling, Cloud Manufacturing;  Complex designs;  Dynamic environments;  Manufacturing cloud services;  Meta heuristic algorithm;  Networked-manufacturing;  Scheduling problem;  Service Oriented, Deep learning},
funding_details={National Natural Science Foundation of ChinaNational Natural Science Foundation of China, NSFC, 61873014},
funding_details={National Basic Research Program of China (973 Program)National Basic Research Program of China (973 Program), 2018YFB1702703},
funding_text 1={ACKNOWLEDGMENTS This work was supported by the National Natural Science Foundation of China (NSFC) under Grant Nos. 61873014 and the National Key Research and Development Program of China under Grant No. 2018YFB1702703.},
references={Zhang, L., Luo, Y., Tao, F., Li, B.H., Ren, L., Zhang, X., Cloud manufacturing: A new manufacturing paradigm (2014) Enterprise Information Systems, 8, pp. 167-187; Liu, Y., Wang, L., Wang, X.V., Xu, X., A revisit to cloud manufacturing (2018) China Mechanical Engineering, 29, pp. 2226-2237; Liu, Y., Wang, L., Wang, X.V., Xu, X., Zhang, L., Scheduling in cloud manufacturing: State-of-the-art and research challenges (2018) International Journal of Production Research; Li, Y., (2017) Deep Reinforcement Learning: An Overview; Mao, H., Alizadeh, M., Menache, I., Kandula, S., Resource management with deep reinforcement learning (2016) Proceedings of the 15th ACM Workshop on Hot Topics in Networks, pp. 50-56. , Atlanta, GA, USA; Cao, Y., Wang, S., Kang, L., Gao, Y., A TQCS-based service selection and scheduling strategy in cloud manufacturing (2016) The International Journal of Advanced Manufacturing Technology, 82, pp. 235-251; Akbaripour, H., Houshmand, M., Woensel, T., Mutlu, N., Cloud manufacturing service selection optimization and scheduling with transportation considerations: Mixed-integer programming models (2017) The International Journal of Advanced Manufacturing Technology, 95, pp. 43-70; Li, W., Zhu, C., Yang, L.T., Shu, L., Ngai, E.C.H., Ma, Y., Subtask scheduling for distributed robots in cloud manufacturing (2017) IEEE Systems Journal, 11, pp. 941-950; Liu, Y., Xu, X., Zhang, L., Tao, F., An extensible model for multitask-oriented service composition and scheduling in cloud manufacturing (2016) Journal of Computing and Information Science in Engineering, 16, p. 041009; Liu, Y., Xu, X., Zhang, L., Wang, L., Zhong, R.Y., Workload-based multi-task scheduling in cloud manufacturing (2017) Robotics and Computer-Integrated Manufacturing, 45, pp. 3-20; Silver, D., Huang, A., Maddison, C.J., Guez, A., Sifre, L., Driessche Den Van, G.D., Mastering the game of Go with deep neural networks and tree search (2016) Nature, 529, pp. 484-489; Silver, D., Schrittwieser, J., Simonyan, K., Antonoglou, I., Huang, A., Guez, A., Mastering the game of Go without human knowledge (2017) Nature, 550, pp. 354-359; Mnih, V., Kavukcuoglu, K., Silver, D., Graves, A., Antonoglou, I., Wierstra, D., Playing Atari with deep reinforcement learning (2013) Proceedings of the Workshops at the 26th Neural Information Processing Systems 2013, pp. 201-220. , Lake Tahoe, USA; Mnih, V., Kavukcuoglu, K., Silver, D., Rusu, A.A., Veness, J., Bellemare, M.G., Human-level control through deep reinforcement learning (2015) Nature, 518, pp. 529-533; Van Hasselt, H., Guez, A., Silver, D., Deep reinforcement learning with double Q learning (2016) Proceedings of the AAAI Conference on Artificial Intelligence, pp. 2094-2100. , Phoenix, USA; Bellemare, M.G., Ostrovski, G., Guez, A., Thomas, P.S., Munos, R., Increasing the action gap: New operators for reinforcement learning (2016) Proceedings of the AAAI Conference on Artificial Intelligence, pp. 1476-1483. , Phoenix, USA; Schaul, T., Quan, J., Antonoglou, I., Silver, D., Prioritized experience replay (2016) Proceedings of the 4th International Conference on Learning Representations, pp. 322-355. , San Juan, Puerto Rico; Wang, Z., Schaul, T., Hessel, M., Van Hasselt, H., Lanctot, M., De Freitas, N., Dueling network architectures for deep reinforcement learning (2016) Proceedings of the International Conference on Machine Learning, pp. 1995-2003. , New York. USA; Hausknecht, M., Stone, P., Deep recurrent q-learning for partially observable mdps (2015) AAAI Fall Symposium Series; Lillicrap, T.P., Hunt, J.J., Pritzel, A., Heess, N., Erez, T., Tassa, Y., Continuous control with deep reinforcement learning (2016) International Conference on Learning Representations, pp. 1-14; Mnih, V., Badia, A.P., Mirza, M., Graves, A., Lillicrap, T., Harley, T., Asynchronous methods for deep reinforcement learning (2016) International Conference on Machine Learning, pp. 1928-1937; Kim, G.H., Lee, C.S.G., Genetic reinforcement learning approach to the machine scheduling problem (1995) Proceedings of IEEE International Conference on Robotics and Automation, 1, pp. 196-201; Wang, Y.C., Usher, J.M., Application of reinforcement learning for agent-based production scheduling (2005) Engineering Applications of Artificial Intelligence, 18, pp. 73-82; Stefán, P., Flow-shop scheduling based on reinforcement learning algorithm (2003) Production Systems and Information Engineering, 1, pp. 83-90; Liu, C., Jin, H., Tian, Y., Yu, H., Reinforcement learning approach to re-entrant manufacturing system scheduling (2001) IEEE International Conferences on Info-Tech and Info-Net. Proceedings (Cat. No. 01EX479), 3, pp. 280-285; Wang, Y.C., Usher, J.M., Application of reinforcement learning for agent-based production scheduling (2005) Engineering Applications of Artificial Intelligence, 18, pp. 73-82; Pan, Y., Feng, Y., Zhou, H., Wei, J., Reinforcement learning integrated with simulation for job-shop scheduling system (2007) Control and Decision, 22, pp. 675-679; Waschneck, B., Reichstaller, A., Belzner, L., Altenmüller, T., Bauernhansl, T., Knapp, A., Optimization of global production scheduling with deep reinforcement learning (2018) Procedia CIRP, 72, pp. 1264-2126; Orhean, A.I., IoanRaicu, F., New scheduling approach using reinforcement learning for heterogeneous distributed systems (2018) Journal of Parallel and Distributed Computing, 117, pp. 292-302; Tesauro, G., Jong, N.K., Das, R., Bennani, M.N., On the use of hybrid reinforcement learning for autonomic resource allocation (2007) Cluster Computing, 10, pp. 287-299; Lin, J., Peng, Z., Cui, D., Deep reinforcement learning for multiresource cloud job scheduling (2018) International Conference on Neural Information Processing, pp. 289-302. , Springer, Cham; Wei, Y., Pan, L., Liu, S., Wu, L., Meng, X., Drl-scheduling: An intelligent qos-aware job scheduling framework for applications in clouds (2018) IEEE Access, 6, pp. 55112-55125},
sponsors={IEEE Industrial Electronics Society (IES); Tampere University; The Institute of Electrical and Electronics Engineers (IEEE)},
publisher={Institute of Electrical and Electronics Engineers Inc.},
