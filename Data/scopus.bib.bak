@CONFERENCE{Sun2018,
author={Sun, G. and Zemuy, G.T. and Xiong, K.},
title={Dynamic Reservation and Deep Reinforcement Learning based Autonomous Resource Management for wireless Virtual Networks},
journal={2018 IEEE 37th International Performance Computing and Communications Conference, IPCCC 2018},
year={2018},
doi={10.1109/PCCC.2018.8710960},
art_number={8710960},
note={cited By ; Conference of 37th IEEE International Performance Computing and Communications Conference, IPCCC 2018 ; Conference Date: 17 November 2018 Through 19 November 2018;  Conference Code:148027},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85066482795&doi=10.1109%2fPCCC.2018.8710960&partnerID=40&md5=36644916269dedc331df745d78bf42e4},
affiliation={School of Computer Science and Engineering, University of Electronic Science and Technology of China, Chengdu, 611731, China},
abstract={The next generation network, 5G, is expected to provide service-oriented networks where different applications are served in isolation according to their own requirements. It is challenging to have an efficient common resource allocation mechanism for virtual networks (VNs) that have different objectives. In this work, we propose a dynamic reservation and deep reinforcement learning based autonomous virtual resource management. The infrastructure provider periodically reserves the unused resource to the VNs based on their ratio of minimum resource requirements. Then, the VNs autonomously control their resource allocation by using deep reinforcement learning based on the average quality of service utility and resource utilization of their users. With the defined design pattern in this paper, virtual operators can customize their own utility function and objective function based on their own requirements. We simulate our work to show resource utilization and satisfaction of the VNs. © 2018 IEEE.},
author_keywords={deep reinforcement learning;  network slicing;  network virtualization},
keywords={5G mobile communication systems;  Distributed computer systems;  E-learning;  Machine learning;  Natural resources management;  Next generation networks;  Quality of service;  Reinforcement learning;  Resource allocation, Autonomous resource management;  Infrastructure providers;  Network slicing;  Network virtualization;  Resource requirements;  Resource utilizations;  Service oriented network;  Virtual resource management, Deep learning},
funding_details={National Natural Science Foundation of ChinaNational Natural Science Foundation of China, NSFC, 61771098},
funding_details={Fundamental Research Funds for the Central UniversitiesFundamental Research Funds for the Central Universities, ZYGX2018J049},
funding_text 1={ACKNOWLEDGMENT This work is supported by National Natural Science Research Foundation of China, Grant no. 61771098 and the Fundamental Research Funds for the Central Universities under grant no. ZYGX2018J049.},
