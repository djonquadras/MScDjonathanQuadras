pages={203-217},
doi={10.1007/978-3-662-48616-0_13},
note={cited By ; Conference of 13th International Conference on Service-Oriented Computing, CSOC 2015 ; Conference Date: 16 November 2015 Through 19 November 2015;  Conference Code:158219},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84952318974&doi=10.1007%2f978-3-662-48616-0_13&partnerID=40&md5=b59cfb413de0fe032eb1b091cda6c786},
affiliation={School of Computer Science and Engineering and Key Laboratory of Computer Network and Information Integration, Southeast University, Nanjing, China; College of Computing and Information Sciences, Rochester Institute of Tech, Rochester, United States},
abstract={Service composition offers a powerful software paradigm to build complex and value-added applications by exploiting a service oriented architecture. However, the frequent changes in the internal and external environment demand adaptiveness of a composition solution. Meanwhile, the increasingly complex user requirements and the rapid growth of the composition space give rise to the scalability issue. To address these key challenges, we propose a new service composition scheme, integrating gaussian process with reinforcement learning for adaptive service composition. It uses kernel function approximation to predict the distribution of the objective function value with strong communication skills and generalization ability based on an off-policy Q-learning algorithm. The experimental results demonstrate that our method clearly outperforms the standard Q-learning solution for service composition. © Springer-Verlag Berlin Heidelberg 2015.},
keywords={Application programs;  Approximation algorithms;  Distributed computer systems;  Gaussian distribution;  Gaussian noise (electronic);  Information services;  Learning algorithms;  Quality of service;  Reinforcement learning, Communication skills;  External environments;  Gaussian Processes;  Generalization ability;  Objective function values;  Q-learning algorithms;  Service compositions;  Value added applications, Service oriented architecture (SOA)},
funding_details={61232007, 61532013},
funding_details={Humanities and Social Science Fund of Ministry of Education of ChinaHumanities and Social Science Fund of Ministry of Education of China, 20120092110028},
funding_text 1={This work is partially supported by NSFC Key Projects (No. 61232007 and 61532013) and Doctoral Fund of Ministry of Education of China (No. 20120092110028).},
references={Barto, A.G., (1998) Reinforcement Learning: An Introduction, , MIT press, Cambridge; Busoniu, L., Reinforcement learning and dynamic programming using function approximators (2010) Automation and Control Engineering Series; Carl Edward Rasmussen, M.K., Gaussian processes in reinforcement learning (2004) Adv. Neural Inf. Process. Syst, 16 (2004), pp. 751-759; Constantinescu, I., Faltings, B., Binder, W., Large scale, type-compatible service composition (2004) Proceedings of the IEEE International Conference on Web Services (ICWS, pp. 506-513. , IEEE; Csató, L., Opper, M., Sparse on-line gaussian processes (2002) Neural Comput, 14 (3), pp. 641-668; Dustdar, S., Schreiner, W., A survey on web services composition (2005) Int. J. Web Grid Serv, 1 (1), pp. 1-30; Engel, Y., (2005) Algorithms and Representations for Reinforcement Learning, , Ph.D. thesis, Citeseer; Engel, Y., Mannor, S., Meir, R., Bayes meets bellman: The gaussian process approach to temporal difference learning (2003) ICML, 20, p. 154; Engel, Y., Mannor, S., Meir, R., Reinforcement learning with gaussian processes (2005) Proceedings of the 22Nd International Conference on Machine Learning, pp. 201-208. , ACM; Even-Dar, E., Mansour, Y., Learning rates for Q-learning (2004) J. Mach. Learn. Res, 5, pp. 1-25; Gärtner, T., Driessens, K., Ramon, J., Graph kernels and gaussian processes for relational reinforcement learning (2003) ILP 2003. LNCS (LNAI, 2835, pp. 146-163. , In: Horváth, T., Yamamoto, A. (eds.), Springer, Heidelberg; Gosavi, A., A tutorial for reinforcement learning (2011) Department of Engineering Management and Systems Engineering; Ko, J., Klein, D.J., Fox, D., Haehnel, D., Gaussian processes and reinforcement learning for identification and control of an autonomous blimp (2007) 2007 IEEE International Conference on Robotics and Automation, pp. 742-747. , IEEE; Liu, Q., Sun, Y., Zhang, S., A scalable web service composition based on a strategy reused reinforcement learning approach (2011) 2011 Eighth Web Information Systems and Applications Conference (WISA, pp. 58-62. , IEEE; Moustafa, A., Zhang, M., Multi-objective service composition using reinforcement learning (2013) ICSOC 2013. LNCS, 8274, pp. 298-312. , In: Basu, S., Pautasso, C., Zhang, L., Fu, X. (eds.), Springer, Heidelberg; Oh, S.C., Lee, D., Kumara, S.R., Effective web service composition in diverse and large-scale service networks (2008) IEEE Trans. Serv. Comput. (TSC), 1 (1), pp. 15-32; Rasmussen, C.E., (2006) Gaussian Processes for Machine Learning; Taylor, G., Parr, R., Kernelized value function approximation for reinforcement learning (2009) Proceedings of the 26Th Annual International Conference on Machine Learning, pp. 1017-1024. , ACM; Trummer, I., Faltings, B., Optimizing the tradeoff between discovery, composition, and execution cost in service composition (2011) Proceedings of the IEEE International Conference on Web Services (ICWS, pp. 476-483. , IEEE; Wang, H., Chen, X., Wu, Q., Yu, Q., Zheng, Z., Bouguettaya, A., Integrating on-policy reinforcement learning with multi-agent techniques for adaptive service composition (2014) ICSOC 2014. LNCS, 8831, pp. 154-168. , In: Franch, X., Ghose, A.K., Lewis, G.A., Bhiri, S. (eds.), Springer, Heidelberg; Wang, H., Wang, X., A novel approach to large-scale services composition (2013) Apweb 2013. LNCS, 7808, pp. 220-227. , In: Ishikawa, Y., Li, J., Wang, W., Zhang, R., Zhang, W. (eds.), Springer, Heidelberg; Wang, H., Wu, Q., Chen, X., Yu, Q., Zheng, Z., Bouguettaya, A., Adaptive and dynamic service composition via multi-agent reinforcement learning (2014) Proceedings of the IEEE International Conference on Web Services (ICWS, pp. 447-454. , IEEE; Wang, H., Zhou, X., Zhou, X., Liu, W., Li, W., Bouguettaya, A., Adaptive service composition based on reinforcement learning (2010) ICSOC 2010. LNCS, 6470, pp. 92-107. , In: Maglio, P.P., Weske, M., Yang, J., Fantinato, M. (eds.), Springer, Heidelberg; Wiering, M., Van Otterlo, M., Reinforcement learning (2012) Adaptation, Learning, and Optimization, 12. , Wiering, M., van Otterlo, M. (eds.), Springer, Heidelberg},
