@CONFERENCE{Urakawa2012324,
author={Urakawa, K. and Sugawara, T.},
title={Reorganization of agent networks with reinforcement learning based on communication delay},
journal={Proceedings - 2012 IEEE/WIC/ACM International Conference on Intelligent Agent Technology, IAT 2012},
year={2012},
volume={2},
pages={324-331},
doi={10.1109/WI-IAT.2012.105},
art_number={6511589},
note={cited By ; Conference of 2012 IEEE/WIC/ACM International Conference on Intelligent Agent Technology, IAT 2012 ; Conference Date: 4 December 2012 Through 7 December 2012;  Conference Code:97231},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84878465215&doi=10.1109%2fWI-IAT.2012.105&partnerID=40&md5=2c74678860d9668765a43d64b03df67c},
affiliation={Waseda University, Department of Computer Science and Engineering, Tokyo, Japan},
abstract={We propose the team formation method for task allocations in agent networks by reinforcement learning based on communication delay and by reorganization of agent networks. A task in a distributed environment like an Internet application, such as grid computing and service-oriented computing, is usually achieved by doing a number of subtasks. These subtasks are constructed on demand in a bottom-up manner and must be done with appropriate agents that have capabilities and computational resources required in each subtask. Therefore, the efficient and effective allocation of tasks to appropriate agents is a key issue in this kind of system. In our model, this allocation problem is formulated as the team formation of agents in the task-oriented domain. From this perspective, a number of studies were conducted in which learning and reorganization were incorporated. The aim of this paper is to extend the conventional method from two viewpoints. First, our proposed method uses only information available locally for learning, so as to make this method applicable to real systems. Second, we introduce the elimination of links as well as the generation of links in the agent network to improve learning efficiency. We experimentally show that this extension can considerably improve the efficiency of team formation compared with the conventional method. We also show that it can make the agent network adaptive to environmental changes. © 2012 IEEE.},
author_keywords={Distributed cooperative;  Multi-agent reinforcement learning;  Reorganization;  Team formation},
keywords={Computational resources;  Distributed cooperative;  Distributed environments;  Environmental change;  Multi-agent reinforcement learning;  Reorganization;  Service oriented computing;  Team formation, Grid computing;  Intelligent agents, Reinforcement learning},
funding_details={Japan Society for the Promotion of ScienceJapan Society for the Promotion of Science, JSPS, 23650075},
references={Stein, S., Gerding, E., Jennings, N.R., Optimal Task Migration in Service-Oriented Systems: Algorithms and Mechanisms Proceedings of the 19th European Conference on Artificial Intelligence. Amsterdam, the Netherlands, 2010, pp. 73-78; Eberling, M., Büning, H.K., Self-Adaptation Strategies to Favor Cooperation (2010) KES-AMSTA'10, pp. 223-232. , Proceedings of the 4th KES International Conference on Agent and Multi-Agent Systems: Technologies and Applications, Part I, ser. Springer-Verlag; Gaston, M.E., DesJardins, M., Agent-Organized Networks for Dynamic Team Formation Proceedings of the Fourth International Joint Conference on Autonomous Agents and Multiagent Systems, AAMAS '05. New York, NY, USA, 2005, pp. 230-237; Sheholy, O., Kraus, S., Methods for Task Allocation via Agent Coalition Formation (1998) Journal of Artificial Intelligence, 101, pp. 165-200; Abdallah, S., Lesser, V., Organization-Based Cooperative Coalition Formation Proceedings of the IEEE/WIC/ACM International Conference on Intelligent Agent Technology, 2004. (IAT 2004), Sept. 2004, pp. 162-168; Katayanagi, R., Sugawara, T., Efficient Team Formation Based on Learning and Reorganization and Influence of Communication Delay IEEE International Conference on Computer and Information Technology, 2011, pp. 563-570; Jurasovic, K., Kusek, M., Jezic, G., Team Formation and Optimization for Service Provisioning (2010) Proceedings of the 4th KES International Conference on Agent and Multi-Agent Systems: Technologies and Applications, Part I, KES-AMSTA'10, pp. 213-222. , Springer-Verlag; Abdallah, S., Lesser, V., Multiagent Reinforcement Learning and Self-Organization in a Network of Agents (2007) Proceedings of the Sixth International Joint Conference on Autonomous Agents and Multi-Agent Systems, pp. 172-179. , Honolulu: IFAAMAS, May},
correspondence_address1={Waseda University, , Tokyo, Japan},
sponsors={IEEE},
address={Macau},
isbn={9780769548807},
language={English},
abbrev_source_title={Proc. - IEEE/WIC/ACM Int. Conf. Intelligent Agent Technol., IAT},
document_type={Conference Paper},
source={Scopus},
}

@CONFERENCE{Xu201270,
author={Xu, W. and Cao, J. and Zhao, H. and Wang, L.},
title={A multi-agent learning model for service composition},
journal={Proceedings - 2012 IEEE Asia-Pacific Services Computing Conference, APSCC 2012},
year={2012},
pages={70-75},
doi={10.1109/APSCC.2012.44},
art_number={6478200},
note={cited By ; Conference of 2012 7th IEEE Asia-Pacific Services Computing Conference, APSCC 2012 ; Conference Date: 6 December 2012 Through 8 December 2012;  Conference Code:96533},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84876111421&doi=10.1109%2fAPSCC.2012.44&partnerID=40&md5=abf9663697c2949416d33629ae6676f3},
affiliation={Dept. of Computer Science and Engineering, Shanghai Jiao Tong University, Shanghai, China; Dept. of Computer Science and Engineering, University of Shanghai for Science and Engineering, Shanghai, China},
abstract={Agent technology has gained increasing popularity in service oriented architecture (SOA) because of its features of autonomy, initiative, interactivity, persistency and adaptability. There are already a plenty of implementations which integrate SOA with multi-agent systems (MAS). The ability of learning is a significant feature of MAS. This paper proposes a learning model of the service-oriented MAS for the service composition problem. It adopts the principle of reinforcement learning and is based on the Markov game and Q-learning. The reward of the learning procedure is determined by the QoS parameters such as responding time and cost. The mechanism of multi-agent leaning for service composition is introduced. The results of experiments and case study show that our multi-agent learning approach can reach convergence efficiently and it can also accelerate the service composition process based on the knowledge continuously learned from past composition experiences. © 2012 IEEE.},
author_keywords={Goal;  Markov game;  Multi-agent learning;  Multi-agent negotiation;  Multi-agent system;  Q-learning;  Service composition},
keywords={Goal;  Markov games;  Multi agent system (MAS);  Multi-agent learning;  Multiagent negotiation;  Q-learning;  Service compositions, Information services;  Multi agent systems;  Reinforcement learning;  Service oriented architecture (SOA), Quality of service},
