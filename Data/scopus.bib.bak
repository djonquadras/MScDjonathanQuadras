@CONFERENCE{Jungmann2016,
author={Jungmann, A. and Kleinjohann, B.},
title={A holistic and adaptive approach for automated prototyping of image processing functionality},
journal={IEEE International Conference on Emerging Technologies and Factory Automation, ETFA},
year={2016},
volume={2016-November},
doi={10.1109/ETFA.2016.7733522},
art_number={7733522},
note={cited By ; Conference of 21st IEEE International Conference on Emerging Technologies and Factory Automation, ETFA 2016 ; Conference Date: 6 September 2016 Through 9 September 2016;  Conference Code:124646},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84996528901&doi=10.1109%2fETFA.2016.7733522&partnerID=40&md5=e7d26941bcb33fc985f7e243cd7795a3},
affiliation={Cooperative Computing and Communication Laboratory (C-LAB), University of Paderborn, Germany},
abstract={Image Processing is fundamental for any camerabased vision system. In order to automate the prototyping process of image processing solutions to some extend, we propose a holistic, adaptive approach that comprises concepts for specification, composition, recommendation, execution, and rating of image processing functionality. The fundamental idea is to realize image processing applications according to Service-oriented Computing design principles. That is, distinct image processing functionality is encapsulated in terms of stateless services. Services are then used as building blocks for more complex image processing functionality. To automatically compose complex image processing functionality, our proposed approach incorporates a flexible, Artificial Intelligence planning-based forward search algorithm. Decision-making between alternative composition steps is supported by a learning recommendation system, which keeps track of valid composition steps by automatically constructing a composition grammar. In addition, it adapts to solutions of high quality by means of feedback-based Reinforcement Learning techniques. A concrete use case serves as proof of concept and demonstrates the feasibility of our holistic, adaptive approach. © 2016 IEEE.},
author_keywords={Artificial Intelligence;  Image Processing;  Prototyping;  Reinforcement Learning;  Service Composition;  Service Recommendation;  Service-oriented Computing},
keywords={Artificial intelligence;  Automation;  Computer vision;  Decision making;  Distributed computer systems;  Factory automation;  Learning algorithms;  Reinforcement learning;  Software prototyping, Artificial intelligence planning;  Image processing applications;  Prototyping process;  Reinforcement learning techniques;  Search Algorithms;  Service compositions;  Service oriented computing;  Service recommendations, Image processing},
references={Gonzalez, R.C., Woods, R.E., (2006) Digital Image Processing, , Upper Saddle River, NJ, USA: Prentice-Hall, Inc; (2016) Collaborative Research Center 901-On-The-Fly Computing, , http://sfb901.uni-paderborn, de Accessed 2016-04-17; Erl, T., (2005) Service-Oriented Architecture: Concepts, Technology, and Design, , Upper Saddle River, NJ, USA: Prentice Hall; Rozenberg, G., Thiagarajan, P., Petri nets: Basic notions, structure, behaviour (1986) Current Trends in Concurrency, pp. 585-668. , Springer Berlin Heidelberg; Jungmann, A., Kleinjohann, B., Automatic composition of servicebased image processing applications (2016) Currently under Review at 13th IEEE International Conference on Services Computing (SCC), , http://bit.ly/1TcBxlX; Jungmann, A., Jatzkowski, J., Kleinjohann, B., Combining serviceoriented computing with embedded systems-a robotics case study (2015) Proceedings of the 5th IFIP International Embedded Systems Symposium (IESS), , Springer-Verlag; Jungmann, A., Lutterbeck, J., Werdehausen, B., Kleinjohann, B., A test bed for investigating self-x properties in multi-robot societies (2011) Proceedings of the 9th IEEE International Conference on Industrial Informatics (INDIN), pp. 437-442; Jungmann, A., Jatzkowski, J., Kleinjohann, B., Evaluation of color spaces for robust image segmentation (2014) Proceedings of the 9th International Conference on Computer Vision Theory and Applications (VISAPP), pp. 648-655; Jungmann, A., Kleinjohann, B., Kleinjohann, L., Learning service recommendations (2013) International Journal of Business Process Integration and Management, 6 (4), pp. 284-297; Ghallab, M., Nau, D., Traverso, P., (2004) Automated Planning: Theory & Practice, , San Francisco, CA, USA: Morgan Kaufmann; Puterman, M.L., (2005) Markov Decision Processes: Discrete Stochastic Dynamic Programming, , Hoboken, NJ, USA: Wiley-Interscience; Sutton, R.S., Barto, A.G., (1998) Reinforcement Learning: An Introduction, , Cambridge, Massachusetts: MIT Press; Gong, L., Kulikowski, C., Composition of image analysis processes through object-centered hierarchical planning (1995) IEEE Transactions on Pattern Analysis and Machine Intelligence, 17 (10), pp. 997-1009; Laird, J.E., Newell, A., Rosenbloom, P.S., Soar: An architecture for general intelligence (1987) Artif. Intell., 33 (1), pp. 1-64; Clouard, R., Elmoataz, A., Porquet, C., Revenu, M., Borg: A knowledge-based system for automatic generation of image processing programs (1999) IEEE Transactions on Pattern Analysis and Machine Intelligence, 21 (2), pp. 128-144; Nii, H., (1989) Introduction Blackboard Architecture and Applications, pp. xix-xxix. , Academic Press; Town, C., Ontological inference for image and video analysis (2006) Machine Vision and Applications, 17 (2), pp. 94-115; Harnad, S., The symbol grounding problem (1990) Phys. D, 42 (1-3), pp. 335-346; Dennett, D., Cognitive wheels: The frame problem of AI (1984) Minds, Machines and Evolution, pp. 129-151. , C. Hookway, Ed. Cambridge: Cambridge University Press; Maillot, N., Thonnat, M., Ontology based complex object recognition (2008) Image Vision Comput., 26 (1), pp. 102-113; Maillot, N., Thonnat, M., Boucher, A., Towards ontology-based cognitive vision (2004) Machine Vision and Applications, 16 (1), pp. 33-40},
