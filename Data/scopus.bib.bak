
@ARTICLE{Shen20215706,
author={Shen, S. and Zhang, T. and Mao, S. and Chang, G.-K.},
title={DRL-Based Channel and Latency Aware Radio Resource Allocation for 5G Service-Oriented RoF-MmWave RAN},
journal={Journal of Lightwave Technology},
year={2021},
volume={39},
number={18},
pages={5706-5714},
doi={10.1109/JLT.2021.3093760},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85112176835&doi=10.1109%2fJLT.2021.3093760&partnerID=40&md5=975e2f41a231143d3ee22979214ac3ca},
affiliation={School of Electrical and Computer Engineering, Georgia Institute of Technology, Atlanta, GA, United States; Department of Electrical and Computer Engineering, Auburn University, Auburn, AL, United States},
abstract={A channel and latency aware radio resource allocation algorithm based on deep reinforcement learning (DRL) is proposed and evaluated. The proposed scheme aims to optimize the uplink scheduling for service-oriented multi-user millimeter wave (mmWave) radio access networks (RAN) in the 5G era. In the DRL system, multiple application flows are implemented with various statistical models and the key function modules of the system are designed to reflect the operation and requirements of service-oriented RANs. In particular, the mmWave channel characteristics utilized in the system are collected experimentally and verified via a radio-over-fiber (RoF)-mmWave testbed with dynamic channel variations. Results show that the proposed DRL algorithm can operate adaptively to channel variations and achieve at least 12% average reward improvement compared to conventional single-rule schemes, providing joint improvement of bit error rate and latency performance. © 1983-2012 IEEE.},
author_keywords={Deep reinforcement learning;  millimeterwave;  radio resource allocation;  scheduling},
keywords={5G mobile communication systems;  Bit error rate;  Deep learning;  Millimeter waves;  Radio;  Radio-over-fiber;  Reinforcement learning;  Resource allocation, Channel characteristics;  Channel variations;  Latency performance;  Millimeter waves (mmwave);  Multiple applications;  Radio resource allocation;  Radio resource allocation algorithms;  Radio-over-Fiber (RoF), Radio access networks},
funding_details={National Science FoundationNational Science Foundation, NSF, CNS-1821819, CNS-1822055},
funding_text 1={Manuscript received March 16, 2021; revised May 15, 2021; accepted June 22, 2021. Date of publication June 30, 2021; date of current version September 18, 2021. This work was supported in part by NSF under Grants CNS-1822055 and CNS-1821819. (Corresponding author: Shuyi Shen.) Shuyi Shen and Gee-Kung Chang are with the School of Electrical and Computer Engineering, Georgia Institute of Technology, Atlanta, Georgia, GA 30308 USA (e-mail: ssyzoe@gatech.edu; gkchang@ece.gatech.edu).},
references={Alfadhli, Y., Xu, M., Liu, S., Lu, F., Peng, P.-C., Chang, G.-K., Real-time demonstration of adaptive functional split in 5G flexible mobile fronthaul networks (2018) Proc. Opt. Fiber Commun. Conf. Expo., San Diego, CA, USA, pp. 1-3; Parvez, I., Rahmati, A., Guvenc, I., Sarwat, A.I., Dai, H., A survey on low latency towards 5G: RAN, core network and caching solutions (2018) IEEE Commun. Surv. Tut., 20 (4), pp. 3098-3130. , Oct.-Dec; Hu, Q., Liu, Y., Yan, Y., Blough, D.M., End-to-end simulation of mmWave out-of-band backhaul networks in ns-3. (2019) Proc. WNGW NS-3. Assoc. Comput. Machinery, pp. 1-4; User equipment (UE) radio transmission and reception; Part 2: Range 2 Standalone. (2020) 3GPP, , https://www.3gpp.org/ftp/Specs/archive/38series/38.101-2/38101-2-g50.zip, 3 rd Gener. Partnership Project (3GPP), Tech. Spec. 38.101-2, V16.5.0; Zhang, R., An ultra-reliable MMW/FSO A-RoF system based on coordinated mapping and combining technique for 5G and beyond mobile fronthaul (2018) J. Lightw. Technol., 36 (20), pp. 4952-4959. , Oct. 15; Feng, M., Mao, S., Dealing with limited backhaul capacity in millimeter-wave systems: A. deep reinforcement learning approach (2019) IEEE Commun. Mag., 57 (3), pp. 50-55. , Mar; Han, D., Chen, W., Fang, Y., Joint channel and queue aware scheduling for latency sensitive mobile edge computing with power constraints (2020) Proc. IEEE Trans. Wireless Commun., 19 (6), pp. 3938-3951. , Jun; Tseng, S., Liu, Z., Chou, Y., Huang, C., Radio resource scheduling for 5G NR via deep deterministic policy gradient (2019) Proc. IEEE Int. Conf. Commun. Workshops, Shanghai, China, pp. 1-6; Zhang, T., Shen, S., Mao, S., Chang, G.-K., Delay-aware cellular traffic scheduling with deep reinforcement learning (2020) Proc. IEEE Glob. Commun. Conf., Taipei, Taiwan, pp. 1-6; Shen, S., Zhang, T., Mao, S., Chang, G.-K., DRL-Based channel and latency aware scheduling and resource allocation for multi-user millimeter-wave RAN (2021) Proc. Opt. Fiber Commun. Conf. Expo., pp. 1-3; Komíc, J., (2011) Harmonic Mean, pp. 622-624. , in: L. M. (eds) Int. Encyclopedia Stat. Sci.. Springer, Berlin, Heidelberg; Dahlman, E., Scheduling (2018) 5G NR: The Next Generation Wireless Access Technology, 1st Ed., Academic Press, pp. 275-299. , Ericsson; System architecture for the 5G system (5GS) (2019) 3GPP, , https://www.3gpp.org/ftp/Specs/archive/23series/23.501/23501-g20.zip, 3GPP, Tech. Spec. 23. 501, V16.2.0; Study on scenarios and requirements for next generation access technologies (2017) 3GPP, , https://www.3gpp.org/ftp/Specs/archive/38series/38.913/38913-e20.zip, 3GPP, Tech. Rep. 38.913, v14.2.0; White, G., Low latency DOCSIS: Technology overview (2019) DOCSIS Res. Develop., Cable Labs, pp. 1-21. , https://community.cablelabs.com/wiki/plugins/servlet/cablelabs/alfresco/download?id=0affb960-25f4-44f9-b747-74ad8555fd06, Feb; Capozzi, F., Piro, G., Grieco, L.A., Boggia, G., Camarda, P., Downlink packet scheduling in LTE cellular networks: Key design issues and a survey (2013) IEEE Commun. Surv. Tut., 15 (2), pp. 678-700. , Apr.-Jun; Ahmad, A., Beg, M.T., Ahmad, S.N., Resource allocation algorithms in LTE: A comparative analysis (2015) Proc. Annu. IEEE India Conf., New Delhi, India, pp. 1-6; NR physical channels and modulation (2020) 3GPP, , https://www.3gpp.org/ftp/Specs/archive/38series/38.211/38211-g20.zip, 3GPP, Tech. Spec. 38.211, V.16.2.0; Shafik, R.A., Rahman, M.S., Islam, A.R., On the extended relationships among EVM, BER and SNR as performance metrics (2006) Proc. Int. Conf. Elect. Comput. Eng., Dhaka, Bangladesh, pp. 408-411; Forward error correction (FEC) and bit error rate (BER) (2020) Juniper, , https://www.juniper.net/documentation/us/en/software/junos/interfaces-ethernet/topics/topic-map/fec-ber-otn-interfaces.html, Juniper, Dec},
correspondence_address1={Shen, S.; School of Electrical and Computer Engineering, United States; email: ssyzoe@gatech.edu},
publisher={Institute of Electrical and Electronics Engineers Inc.},
