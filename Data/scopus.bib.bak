@ARTICLE{Wang2020551,
author={Wang, H. and Li, J. and Yu, Q. and Hong, T. and Yan, J. and Zhao, W.},
title={Integrating recurrent neural networks and reinforcement learning for dynamic service composition},
journal={Future Generation Computer Systems},
year={2020},
volume={107},
pages={551-563},
doi={10.1016/j.future.2020.02.030},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85079539290&doi=10.1016%2fj.future.2020.02.030&partnerID=40&md5=891b0e3d232dfa8e00a6a6fe0ade4884},
affiliation={School of Computer Science and Engineering and Key Laboratory of Computer Network and Information Integration, Southeast University, SIPAILOU 2, Nanjing, 210096, China; College of Computing and Information Sciences, Rochester Institute of Tech, United States},
abstract={In the service oriented architecture (SOA), software and systems are abstracted as web services to be invoked by other systems. Service composition is a technology, which builds a complex system by combining existing simple services. With the development of SOA and web service technology, massive web services with the same function begin to spring up. These services are maintained by different organizations and have different QoS (Quality of Service). Thus, how to choose the appropriate service to make the whole system to deliver the best overall QoS has become a key problem in service composition research. Furthermore, because of the complexity and dynamics of the network environment, QoS may change over time. Therefore, how to adjust the composition system dynamically to adapt to the changing environment and ensure the quality of the composed service also poses challenges. To address the above challenges, we propose a service composition approach based on QoS prediction and reinforcement learning. Specifically, we use a recurrent neural network to predict the QoS, and then make dynamic service selection through reinforcement learning. This approach can be well adapted to a dynamic network environment. We carry out a series of experiments to verify the effectiveness of our approach. © 2020 Elsevier B.V.},
author_keywords={QoS prediction;  Recurrent neural network;  Reinforcement learning;  Service composition},
keywords={Complex networks;  Forecasting;  Information services;  Recurrent neural networks;  Reinforcement learning;  Service oriented architecture (SOA);  Web services;  Websites, Changing environment;  Dynamic network environment;  Dynamic service composition;  Dynamic service selections;  QoS (quality of service);  Qos predictions;  Service compositions;  Web service technology, Quality of service},
funding_details={National Science FoundationNational Science Foundation, NSF, 1814450, IIS-1814450},
