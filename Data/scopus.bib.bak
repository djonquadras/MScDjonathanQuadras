@CONFERENCE{Jungmann2015755,
author={Jungmann, A. and Kleinjohann, B.},
title={Towards context-sensitive service composition for service-oriented image processing},
journal={Proceedings of the International Conference on Cloud Computing Technology and Science, CloudCom},
year={2015},
volume={2015-February},
number={February},
pages={755-758},
doi={10.1109/CloudCom.2014.154},
art_number={7037756},
note={cited By ; Conference of 2014 6th IEEE International Conference on Cloud Computing Technology and Science, CloudCom 2014 ; Conference Date: 15 December 2014 Through 18 December 2014;  Conference Code:112984},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84937958406&doi=10.1109%2fCloudCom.2014.154&partnerID=40&md5=0ba55cda3cc21307894acb4fddabcdce},
affiliation={Cooperative Computing and Communication Laboratory (C-LAB), University of Paderborn, Germany},
abstract={Automatically composing service-based software solutions is a challenging task. Considering context information during this service composition process is even more challenging. In domains such as image processing, however, context-sensitivity is inherent and cannot be ignored when developing techniques for automatic service composition. Formal approaches tend to create ambiguous solutions, whenever the expressive power of the applied formalism is limited. For example, services may have the same formal specification, although their actual functionality depends on the concrete context. In order to satisfy individual user requests while providing data-dependent functionality, formal approaches have to be extended. We propose to incorporate Reinforcement Learning techniques and combine them with planning based composition approaches. While planning ensures formally correct solutions, learning enables the composition process to resolve ambiguity by implicitly considering context information. Preliminary results show that our combined approach adapts to a static context while still satisfying formally specified requirements. © 2014 IEEE.},
author_keywords={AI planning;  Context-sensitive service composition;  Image processing;  Q-learning;  Service-oriented computing},
keywords={Cloud computing;  Quality of service;  Reinforcement learning, AI planning;  Automatic service composition;  Context information;  Context-sensitive services;  Q-learning;  Reinforcement learning techniques;  Service composition process;  Service oriented computing, Image processing},
references={Rao, J., Su, X., A survey of automated web service composition methods (2005) Proceedings of the First International Conference on Semantic Web Services and Web Process Composition (SWSWPC), pp. 43-54. , Springer-Verlag; Sutton, R.S., Barto, A.G., (1998) Reinforcement Learning: An Introduction, , Cambridge, Massachusetts, USA: MIT Press; Erl, T., (2005) Service-Oriented Architecture: Concepts, Technology, and Design, , Upper Saddle River, NJ, USA: Prentice Hall PTR; (2014) OpenCV-Open Source Computer Vision, , http://opencv.org/, accessed: 2014-10-14; Doliwa, D., Horzelski, W., Jarocki, M., Niewiadomski, A., Penczek, W., Pólrola, A., Szreter, M., Zbrzezny, A., Planics-a web service composition toolset (2011) Fundam. Inf., 112 (1), pp. 47-71; Clouard, R., Renouf, A., Revenu, M., An ontology-based model for representing image processing application objectives (2010) International Journal of Pattern Recognition and Artificial Intelligence, 24 (8), pp. 1181-1208; Ghallab, M., Nau, D., Traverso, P., (2004) Automated Planning: Theory & Practice, , Morgan Kaufmann; Russell, S., Norvig, P., (2010) Artificial Intelligence-A Modern Approach, , 3rd ed. Pearson; Jungmann, A., Kleinjohann, B., Kleinjohann, L., Learning service recommendations (2013) International Journal of Business Process Integration and Management, 6 (4), pp. 284-297; Jungmann, A., Mohr, F., Kleinjohann, B., Applying reinforcement learning for resolving ambiguity in service composition (2014) Proceedings of the 7th International Conference on Service Oriented Computing and Applications (SOCA). IEEE; Puterman, M.L., (2005) Markov Decision Processes: Discrete Stochastic Dynamic Programming, , Wiley-Interscience; Watkins, C.J.C.H., Dayan, P., Q-learning (1992) Machine Learning, pp. 279-292},
sponsors={et al.; IEEE; IEEE Cloud Computing Initiative (CCI); IEEE Computer Society; IEEE Computer Society Cloud Computing Special Technical Committee (CS CC STC); IEEE Computer Society Technical Committee on Scalable Computing (TCSC)},
publisher={IEEE Computer Society},
issn={23302194},
isbn={9781479940936},
language={English},
abbrev_source_title={Proc. Int. Conf. Cloud Comput. Technol. Sci., CloudCom},
document_type={Conference Paper},
source={Scopus},
}

