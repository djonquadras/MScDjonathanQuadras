@CONFERENCE{Liu2020,
author={Liu, Y. and Yao, J. and Lin, T. and Xu, H. and Shi, F. and Xiao, Y. and Zhang, L. and Wang, L.},
title={A framework for industrial robot training in cloud manufacturing with deep reinforcement learning},
journal={ASME 2020 15th International Manufacturing Science and Engineering Conference, MSEC 2020},
year={2020},
volume={2},
doi={10.1115/MSEC2020-8355},
art_number={V002T07A024},
note={cited By ; Conference of ASME 2020 15th International Manufacturing Science and Engineering Conference, MSEC 2020 ; Conference Date: 3 September 2020;  Conference Code:166527},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85101429070&doi=10.1115%2fMSEC2020-8355&partnerID=40&md5=ac786245464e7216b4cad81d9169f94f},
affiliation={Center for Intelligent Manufacturing Systems and Robotics, School of Mechano-Electronic Engineering, Xidian University, Xi'an, 710071, China; State Key Laboratory of Intelligent Manufacturing System Technology, Beijing, 100854, China; School of Mechanical Engineering, Xi'an Jiaotong University, Xi'an, 710049, China; School of Automation Science and Electrical Engineering, Beihang University, Beijing, 100191, China; Department of Production Engineering, KTH Royal Institute of Technology, Stockholm, 100 44, Sweden},
abstract={Cloud manufacturing is a service-oriented networked manufacturing model that embraces the concept of 'Everything-as-a-Service'. In cloud manufacturing, distributed manufacturing resources encompassed in the product lifecycle are transformed into manufacturing services. Industrial robots are an important category of manufacturing resources in cloud manufacturing. During the past years, robots have been demonstrated to be able to learn various dexterous manipulation skills through training with deep reinforcement learning (DRL). In cloud manufacturing, there are many complex industrial application scenarios that require dexterous robots. Hence, robot training, which enables robots to learn various manipulation skills, becomes an important requirement for cloud manufacturing in the future, leading to the concept of 'Robot Training-as-a-Service'. This paper focuses on industrial robot training in the context of cloud manufacturing. First, related work on cloud manufacturing, DRL, DRL-based robot training, and cloud-edge collaboration is briefly reviewed and analyzed. Then, a framework for industrial robot training in cloud manufacturing with DRL is proposed, and a simplified case study is presented to demonstrate the basic principle of the framework. Finally, possible future research issues are discussed. Copyright © 2020 ASME},
author_keywords={Cloud manufacturing;  Deep reinforcement learning;  Industrial robot training;  Transfer learning},
keywords={Computer aided manufacturing;  Deep learning;  Educational robots;  Industrial robots;  Life cycle;  Manufacture;  Reinforcement learning;  Robot learning, Basic principles;  Cloud Manufacturing;  Dexterous manipulation;  Distributed manufacturing;  Manufacturing resource;  Manufacturing service;  Networked-manufacturing;  Product-life-cycle, Engineering education},
funding_details={National Natural Science Foundation of ChinaNational Natural Science Foundation of China, NSFC, 61873014, 61973243},
funding_text 1={This research is supported by the Open Fund of State Key Laboratory of Intelligent Manufacturing System Technology and the National Natural Science Foundation of China under Grant Nos. 61973243 and 61873014.},
references={Zhang, L, Luo, Y, Tao, F, Cloud manufacturing: a new manufacturing paradigm (2014) Enterprise Information Systems, 8 (2), pp. 167-187; Liu, Y, Wang, L, Wang, X V., Cloud manufacturing: latest advancements and future trends (2018) Procedia Manufacturing, 25, pp. 62-73; Liu, Y, Wang, L, Wang, X V, Cloud manufacturing: key issues and future perspectives (2019) International Journal of Computer Integrated Manufacturing, 32 (9), pp. 858-874; Liu, Y, Xu, X., Industry 4.0 and cloud manufacturing: A comparative analysis (2017) Journal of Manufacturing Science and Engineering, 139 (3), p. 034701; Chen, Y, Du, Z, García-Acosta, M., Robot as a service in cloud computing (2010) 5th IEEE International Symposium on Service Oriented System Engineering, pp. 151-158; Li, B H, Zhang, L, Wang, S L, Cloud manufacturing: a new service-oriented networked manufacturing model (2010) Computer integrated manufacturing systems, 16 (1), pp. 1-7; Li, B H, Chai, X D, Hou, B C, Cloud manufacturing system 3.0 - a new intelligent manufacturing system in the era of "intelligence +" Computer integrated manufacturing system, 25 (12), pp. 2997-3012; Liu, Y, Wang, L, Wang, X V, Scheduling in cloud manufacturing: state-of-the-art and research challenges (2019) International Journal of Production Research, 57 (15-16), pp. 4854-4879; Li, W, Zhu, C, Yang, L T, Subtask scheduling for distributed robots in cloud manufacturing (2015) IEEE Systems Journal, 11 (2), pp. 941-950; Nielsen, I, Dang, Q V, Bocewicz, G, A methodology for implementation of mobile robot in adaptive manufacturing environments (2017) Journal of Intelligent Manufacturing, 28 (5), pp. 1171-1188; Wang, X V, Wang, L, Mohammed, A, Ubiquitous manufacturing system based on Cloud: A robotics application (2017) Robotics and Computer-Integrated Manufacturing, 45, pp. 116-125; Adamson, G, Wang, L, Holm, M, Adaptive robot control as a service in cloud manufacturing (2015) ASME 2015 International Manufacturing Science and Engineering Conference, , American Society of Mechanical Engineers Digital Collection; Sutton, R S, Barto, A G., (2018) Reinforcement learning: An introduction, , MIT press; Mnih, V, Kavukcuoglu, K, Silver, D, (2013) Playing atari with deep reinforcement learning, , arXiv preprint arXiv:1312.5602; Zeng, A, Song, S, Welker, S, Learning synergies be-tween pushing and grasping with self-supervised DRL (2018) IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS), pp. 4238-4245; Gu, S, Holly, E, Lillicrap, T, DRLfor robotic manip-ulation with asynchronous off-policy updates (2017) IEEE in-ternational conference on robotics and automation (ICRA), pp. 3389-3396; Sartoretti, G, Wu, Y, Paivine, W, Distributed reinforcement learning for multi-robot decentralized collective construction (2019) Distributed Autonomous Robotic Systems, pp. 35-49. , Springer, Cham; Pachtrachai, K, Vasconcelos, F, Chadebecq, F, Ad-joint transformation algorithm for hand-eye calibration with applications in robotic assisted surgery (2018) Annals of biomedical engineering, 46 (10), pp. 1606-1620; Sun, W, Liu, C, Zhu, J., A Remote Controlled Mobile Robot Based on Wireless Transmission (2018) 2nd IEEE Advanced Information Management, Communicates, Electronic and Automation Control Conference (IMCEC), pp. 2173-2176; Rusu, A A, Rabinowitz, N C, Desjardins, G, (2016) Progressive neural networks, , arXiv preprint arXiv:1606.04671; Torrey, L, Shavlik, J., Transfer learning, Handbook of research on machine learning applications and trends: algorithms, methods, and techniques (2010) IGI Global, pp. 242-264; Oquab, M, Bottou, L, Laptev, I, Learning and transferring mid-level image representations using convolutional neural networks (2014) Proceedings of the IEEE conference on computer vision and pattern recognition, pp. 1717-1724; Parisotto, E, Ba, J L, Salakhutdinov, R., (2015) Actor-mimic: Deep multitask and transfer reinforcement learning, , arXiv preprint arXiv:1511.06342; Rusu, A A, Colmenarejo, S G, Gulcehre, C, (2015) Policy distillation, , arXiv preprint arXiv:1511.06295; Beck, M T, Werner, M, Feld, S, Mobile edge computing: A taxonomy, Proc. of the Sixth International Conference on Advances in Future Internet (2014), pp. 48-55. , Citeseer; Ning, Z, Dong, P, Wang, X, Deep reinforcement learning for vehicular edge computing: An intelligent offloading system (2019) ACM Transactions on Intelligent Systems and Technology (TIST), 10 (6), pp. 1-24; Matula, V C, Erhart, G, Skiba, D., Service robot communication systems and system self-configuration, , U.S. Patent Application 10/040,201.2018-8-7; Ping, Zou, Hua, Zhang, Kaidi, Ma, Research on edge-oriented manufacturing resource-aware access and intelligent gateway technology Computer Integrated Manufacturing Systems, 26, pp. 40-48; Wang, S, Yang, S, Zhao, C., SurveilEdge: Real-time Video Query based on Collaborative Cloud-Edge Deep Learning, , arXiv preprint arXiv: 2001.01043, 2020; Mach, P, Becvar, Z., Mobile edge computing: A survey on architecture and computation offloading (2017) IEEE Communications Surveys & Tutorials, 19 (3), pp. 1628-1656; Lee, J, Lapira, E, Bagheri, B, Recent advances and trends in predictive manufacturing systems in big data environment (2013) Manufacturing letters, 1 (1), pp. 38-41; Givehchi, O, Trsek, H, Jasperneite, J., Cloud computing for industrial automation systems-A comprehensive overview (2013) IEEE 18th Conference on Emerging Technologies & Factory Automation (ETFA), pp. 1-4},
sponsors={Manufacturing Engineering Division},
publisher={American Society of Mechanical Engineers},
