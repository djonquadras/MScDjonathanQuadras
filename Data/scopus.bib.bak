@CONFERENCE{Yang201195,
author={Yang, B. and Xu, X. and Tan, F. and Park, D.H.},
title={An utility-based job scheduling algorithm for cloud computing considering reliability factor},
journal={Proceedings - 2011 International Conference on Cloud and Service Computing, CSC 2011},
year={2011},
pages={95-102},
doi={10.1109/CSC.2011.6138559},
art_number={6138559},
note={cited By ; Conference of 2011 International Conference on Cloud and Service Computing, CSC 2011 ; Conference Date: 12 December 2011 Through 14 December 2011;  Conference Code:88618},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84863123832&doi=10.1109%2fCSC.2011.6138559&partnerID=40&md5=08f7511a4f367afb48b7393504360778},
affiliation={State Key Laboratory of Software Engineering, Wuhan University, Wuhan, China; School of Computer Science and Engineering, University of Electronic Science and Technology of China, Chengdu, 611731, China; Department of Industrial Engineering, University of Electronic Science and Technology of China, Chengdu, 611731, China; Department of Information and Statistics, Hallym University, Chuncheon 200-702, South Korea},
abstract={Cloud computing' service-oriented characteristics advance a new way of service provisioning called utility based computing. However, toward the practical application of commercialized Cloud, we encounter two challenges: i) there is no well-defined job scheduling algorithm for the Cloud that considers the system state in the future, particularly under overloading circumstances; ii) the existing job scheduling algorithms under utility computing paradigm do not take hardware/software failure and recovery in the Cloud into account. In an attempt to address these challenges, we introduce the failure and recovery scenario in the Cloud computing entities and propose a Reinforcement Learning (RL) based algorithm to make job scheduling fault-tolerable while maximizing utilities attained in the long term. We carry out experimental comparison with Resource-constrained Utility Accrual algorithm (RUA), Utility Accrual Packet scheduling algorithm (UPA) and LBESA to demonstrate the feasibility of our proposed approach. © 2011 IEEE.},
author_keywords={Cloud Computing;  Fault Recovery;  Job Scheduling;  Reinforcement Learning;  Utility Computing},
keywords={Experimental comparison;  Fault recovery;  Hardware/software;  Job scheduling;  Job scheduling algorithms;  Packet scheduling algorithm;  Reliability factor;  Resource-constrained;  Service Oriented;  Service provisioning;  System state;  Utility accruals;  Utility computing, Human computer interaction;  Quality of service;  Reinforcement learning;  Scheduling;  Scheduling algorithms, Cloud computing},
references={Armbrust, M., Fox, A., (2009) Above the Clouds: A Berkeley View of Cloud Computing, , Technical Report, No. UCB/EECS-2009-28; Buyya, R., Yeo, C.S., Venugopal, S., Market-oriented Cloud computing: Vision, hype, and reality for delivering IT services as computing utilities (2008) 10th IEEE International Conference on High Performance Computing and Communications (HPCC), pp. 5-13; Buyya, R., Yeo, C.S., Venugopal, S., Cloud computing and emerging IT platforms: Vision, hype, and reality for delivering computing as the 5th utility (2009) Future Generation Computer Systems, 25 (6), pp. 599-616; Foster, I., Zhao, Y., Raicu, I., Cloud computing and grid computing 360-degree compared (2008) Grid Computing Environments Workshop (GCE), pp. 1-10; Yang, B., Tan, F., Dai, Y.S., Performance evaluation of cloud service considering fault recovery (2011) Journal of Supercomputing, , to appear; Mosse, D., Pollack, M.E., Ronen, Y., Value-density algorithms to handle transient overloads in scheduling (2009) Proceedings of the 11th Euromicro Conference on Real-Time Systems (ECRTS), pp. 278-286; Jensen, E.D., Locke, C.D., Tokuda, H., A time driven scheduling model for real-time operating systems (1985) Proceedings of IEEE Real-Time Systems Symposium (RTSS), pp. 112-122; Wu, H., Ravindran, B., Jensen, E.D., Utility Accrual Scheduling under Arbitrary Time/Utility Functions and Multi-unit Resource Constraints (2004) Proceedings of the 10th Real-Time and Embedded Computing Systems and Applications (RTECSA), pp. 80-98; Wang, J., Ravindran, B., Time-Utility Function-Driven Switched Ethernet: Packet Scheduling Algorithm, Implementation, and Feasibility Analysis (2004) IEEE Transactions on Parallel and Distributed Systems, 15 (1), pp. 1-15; (1998) MK7.3a Release Notes, , The Open Group, The Open Group Research Institute, Cambridge, Massachusetts; Clark, R.K., (1990) Scheduling Dependent Real-time Activities, , Ph.D. Dissertation, Carnegie Mellon University, CMU-CS-90-155; Jensen, E.D.,