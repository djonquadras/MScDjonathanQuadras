@ARTICLE{Xu201295,
author={Xu, C.-Z. and Rao, J. and Bu, X.},
title={URL: A unified reinforcement learning approach for autonomic cloud management},
journal={Journal of Parallel and Distributed Computing},
year={2012},
volume={72},
number={2},
pages={95-105},
doi={10.1016/j.jpdc.2011.10.003},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-84855359756&doi=10.1016%2fj.jpdc.2011.10.003&partnerID=40&md5=80afe8e7e937118ee4fb9d6d2e7b8341},
affiliation={Department of Electrical and Computer Engineering, Wayne State University, Detroit, MI 48202, United States},
abstract={Cloud computing is emerging as an increasingly important service-oriented computing paradigm. Management is a key to providing accurate service availability and performance data, as well as enabling real-time provisioning that automatically provides the capacity needed to meet service demands. In this paper, we present a unified reinforcement learning approach, namely URL, to automate the configuration processes of virtualized machines and appliances running in the virtual machines. The approach lends itself to the application of real-time autoconfiguration of clouds. It also makes it possible to adapt the VM resource budget and appliance parameter settings to the cloud dynamics and the changing workload to provide service quality assurance. In particular, the approach has the flexibility to make a good trade-off between system-wide utilization objectives and appliance-specific SLA optimization goals. Experimental results on Xen VMs with various workloads demonstrate the effectiveness of the approach. It can drive the system into an optimal or near-optimal configuration setting in a few trial-and-error iterations. © 2011 Elsevier Inc. All rights reserved.},
author_keywords={Cloud computing;  Reinforcement learning;  Virtual machine autoconfiguration},
keywords={Auto-configuration;  Changing workload;  Cloud dynamics;  Configuration process;  Parameter setting;  Performance data;  Reinforcement learning approach;  Resource budget;  Running-in;  Service availability;  Service demand;  Service oriented computing;  Service quality assurances;  SLA optimization;  Virtual machines, Computer simulation;  Optimization;  Quality assurance;  Quality of service;  Reinforcement;  Reinforcement learning, Cloud computing},
funding_details={National Science FoundationNational Science Foundation, NSF, CCF-1016966, CNS-0702488, CNS-0914330},
funding_text 1={The authors are grateful to the anonymous reviewers for their constructive comments. This research was supported in part by the US NSF grants CNS-0702488 , CNS-0914330 , and CCF-1016966 .},
references={Abdelzaher, T.F., Shin, K.G., Bhatti, N., Performance guarantees for Web server end-systems: A control-theoretical approach (2002) IEEE Transactions on Parallel and Distributed Systems, 13 (1), pp. 80-96. , DOI 10.1109/71.980028; Atkeson, C.G., Santamar'Ia, J.C., A comparison of direct and model-based reinforcement learning (1997) International Conference on Robotics and Automation; Bar-Hillel, A., Di-Nur, A., Ein-Dor, L., Gilad-Bachrach, R., Ittach, Y., Workstation capacity tuning using reinforcement learning (2007) SC; Bittman, T., The future of infrastructure and operations: The engine of cloud computing (2008) Gartner 27th Annual Data Center Conference, , December; Bu, X., Rao, J., Xu, C.-Z., A reinforcement learning approach to online web system autoconfiguration (2009) Proc. of Int. Conf. on Distributed Computing Systems (ICDCS); Bu, X., Rao, J., Xu, C.-Z., A model-free learning approach for coordinated configuration of virtual machines and appliances (2011) Proc. of MASCOTS; Chung, I.-H., Hollingsworth, J.K., Automated cluster-based web service performance tuning (2004) HPDC, p. 3644; Clark, C., Fraser, K., Hand, S., Hansen, J.G., Jul, E., Limpach, C., Pratt, I., Warfield, A., Live migration of virtual machines (2005) NSDI; Diao, Y., Hellerstein, J., Parekh, S., Shaikh, H., Surendra, M., Controlling quality of service in multi-tier web applications (2006) Proc. of ICDCS; Gupta, D., Cherkasova, L., Gardner, R., Vahdat, A., Enforcing performance isolation across virtual machines in xen (2006) Middleware; Huebscher, M.C., McCann, J.A., A survey of autonomic computing: Degrees, models, and applications (2008) ACM Computing Surveys, 40 (3); (2007) Virtualization and Multicore Innovations Disrupt the Worldwide Server Market, , IDC. document number: 206035; Ipek, E., Mutlu, O., Martinez, J.F., Caruana, R., Self-optimizing memory controllers: A reinforcement learning approach (2008) ISCA; Kaelbling, L.P., Littman, M.L., Moore, A.W., Reinforcement learning: A survey (1996) Journal of Artificial Intelligence Research, 4, pp. 237-285; Kamra, A., Misra, V., Nahum, E., Yaksha: A self-tuning controller for managing the performance of 3-tiered websites (2004) Proc. of IWQoS'04, p. 4756; Kephart, J.O., Chess, D.M., The vision of autonomic computing (2003) IEEE Computer; Kwan, E., Lightstone, S., Storm, A., Wu, A., (2002) Automatic Configuratoin of Ibm db2 Universal Database; Liu, X., Sha, L., Diao, Y., Froehlich, S., Hellerstein, J.L., Parekh, S.S., Online response time optimization of apache web server (2003) IWQoS, p. 461478; Lu, C., Lu, Y., Abdelzaher, T.F., Stankovic, J.A., Son, S.H., Feedback control architecture and design methodology for service delay guarantees in web servers (2006) IEEE Transactions on Parallel and Distributed Systems, 17 (9), pp. 1014-1027. , DOI 10.1109/TPDS.2006.123; Ongaro, D., Cox, A.L., Rixner, S., Scheduling i/o in virtual machine monitors (2008) Poc. of ACM/Usenix Int. Conf. on Virtual Execution Environment (VEE); Padala, P., Shin, K.G., Zhu, X., Uysal, M., Wang, Z., Singhal, S., Merchant, A., Salem, K., Adaptive control of virtualized resources in utility computing environments (2007) EuroSys; Rao, J., Bu, X., Xu, C.-Z., Wang, K., A distributed self-learning approach for elastic provisioning of virtualized cloud resources (2011) Proc. of MASCOTS; Rao, J., Bu, X., Xu, C.-Z., Wang, L.Y., Yin, G., Vconf: A reinforcement learning approach for virtual machine autoconfiguration (2009) Proc. of Int. Conf. on Autonomic Computing (ICAC); Rao, J., Xu, C.-Z., Online measurement of the capacity of multi-tier websites using hardware counters (2008) Proc. of ICDCS, , (An extended version is to appear in IEEE Trans. on Parallel and Distributed Systems); Roderick, L., Zamost, E., Anderson, J., Vmmark: A scalable benchmark for virtualized systems (2006) Technical Report VMware-TR-2006-002, , http://www.vmware.com/products/vmmark, VMware, Inc; Soror, A.A., Minhas, U.F., Aboulnaga, A., Salem, K., Kokosielis,