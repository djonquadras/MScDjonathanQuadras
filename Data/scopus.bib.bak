@ARTICLE{Zhang201922988,
author={Zhang, M. and Tian, G. and Zhang, Y.},
title={A Home Service-Oriented Question Answering System with High Accuracy and Stability},
journal={IEEE Access},
year={2019},
volume={7},
pages={22988-22999},
doi={10.1109/ACCESS.2019.2894438},
art_number={8624414},
note={cited By },
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85062916097&doi=10.1109%2fACCESS.2019.2894438&partnerID=40&md5=a21554ef5f26e3d5efdc409149879000},
affiliation={School of Control Science and Engineering, Shandong University, Jinan, 253000, China; Shenzhen Research Institute, Shandong University, Shenzhen, 518000, China},
abstract={With the development of deep learning, neural network-based (NN-based) methods have been applied in question answering (QA) widely and achieved significant progress. Although an NN-based QA system can obtain better performance and save manual efforts, the system is likely to suffer attacks from the external perturbation, due to its character of being black boxes. Limited in the area of home service, we present an innovative method for constructing an NN-based QA system. In our method, the accuracy can be further increased, and the stability can be enhanced in the meantime. Inspired by observing the process of performing home services, the tool information (tool names and tool sequences) is integrated with question terms, as a way of extending the question representation. The conception of attribution (word importance) is introduced to gauge the word importance since NN-based models can be easily affected by the uninformative question terms. In order to optimize the model parameters effectively, the reinforcement learning is employed and both factors on accuracy and stability are regarded as rules in designing rewards. A few state-of-the-art methods are adopted to evaluate the effectiveness of the proposed method. The experimental results demonstrate that the model ability to produce effective answers in QA can be further improved with our method, and the model stability on perturbations can be enhanced with our method. © 2013 IEEE.},
author_keywords={home service;  neural networks;  Question answering;  reinforcement learning;  stability;  tool information},
keywords={Convergence of numerical methods;  Deep learning;  Machine learning;  Natural language processing systems;  Neural networks;  Stability, External perturbations;  Home services;  Innovative method;  Modeling abilities;  Question Answering;  Question answering systems;  State-of-the-art methods;  Tool information, Reinforcement learning},
funding_details={JCYJ20160331174814755},
funding_details={National Natural Science Foundation of ChinaNational Natural Science Foundation of China, NSFC, 61773239},
funding_text 1={This work was supported in part by the National Natural Science Foundation of China under Grant 61773239, and in part by the Shenzhen Future Industry Special Fund under Grant JCYJ20160331174814755.},
references={Bordes, A., Weston, J., Usunier, N., Open question answering with weakly supervised embedding models (2014) Proc. Joint Eur. Conf. Mach. Learn. Knowl. Discovery Databases, Nancy, France, pp. 165-180; Bordes, A., Chopra, S., Weston, J., Question answering with subgraph embeddings (2014) Proc. Conf. Empirical Methods Natural Lang. Process. (EMNLP), Doha, Qatar, pp. 615-620; Lao, M., Guo, Y., Wang, H., Zhang, X., Multimodal local perception bilinear pooling for visual question answering (2018) IEEE Access, 6, pp. 57923-57932; Perronnin, F., Dance, C., Csurka, G., Bressan, M., Adapted vocabularies for generic visual categorization (2006) Proc. Eur. Conf. Comput. Vis., Berlin, Germany, pp. 464-475; Dong, L., Wei, F., Zhou, M., Xu, K., Question answering over freebase with multi-column convolutional neural networks (2015) Proc. 53rd Annu. Meeting Assoc. Comput. Linguistics 7th Int. Joint Conf. Natural Lang. Process, pp. 260-269. , Beijing, China; Bordes, A., Usunier, N., Chopra, S., Weston, J., (2015) Large-scale Simple Question Answering with Memory Networks, , https://arxiv.org/abs/1506.02075; Neelakantan, A., Le, Q.V., Abadi, M., McCallum, A., Amodei, D., Learning a natural language interface with neural programmer (2017) Proc. Int. Conf. Learn. Represent. (ICLR), pp. 1-13. , San Diego, CA, USA; Yu, A.W., Dohan, D., Le, Q., Luong, T., Zhao, R., Chen, K., Fast and accurate reading comprehension by combining self-attention and convolution (2018) Proc. Int. Conf. Learn. Represent. (ICLR), pp. 1-16. , Vancouver, BC, Canada; Mudrakarta, P.K., Taly, A., Sundararajan, M., Dhamdhere, M., Did the model understand the question? (2018) Proc. 56th Annu. Meeting Assoc. Com-put. Linguistics, Melbourne, pp. 1896-1906. , Victoria, Australia; Sundararajan, M., Taly, A., Yan, Q., (2017) Axiomatic Attribution for Deep Networks, , https://arxiv.org/abs/1703.01365; Jia, R., Liang, P., Adversarial examples for evaluating reading comprehension systems (2017) Proc. Conf. Empirical Methods Natural Lang. Process, pp. 2021-2031. , Copenhagen, Denmark; Reddy, S., Transforming dependency structures to logical forms for semantic parsing (2016) Proc. Trans. Assoc. Comput. Linguistics, Boston, MA, USA, pp. 127-141; Yih, S.W., Chang, M.W., He, X., Gao, J., Semantic parsing via staged query graph generation: Question answering with knowledge base (2015) Proc. Joint Conf. 53rd Annu. Meeting ACL 7th Int. Joint Conf. Natural Lang. Process, pp. 1321-1331. , Beijing, China; Yih, W.-T., Richardson, M., Meek, C., Chang, M.-W., Suh, J., The value of semantic parse labeling for knowledge base question answering (2016) Proc. 54th Annu. Meeting Assoc. Comput. Linguistics, Berlin, Germany, pp. 201-206; Berant, J., Chou, A., Frostig, R., Liang, P., Semantic parsing on freebase from question-answer pairs (2013) Proc. Conf. Empirical Methods Natural Lang. Process, pp. 1533-1544. , Seattle, WA, USA; Xu, K., Reddy, S., Feng, Y., Huang, S., Zhao, D., Question answering on freebase via relation extraction and textual evidence (2016) Proc. 54th Annu. Meeting Assoc. Comput. Linguistics, pp. 2326-2336. , Berlin, Germany; Bahdanau, D., Cho, K., Bengio, Y., Neural machine translation by jointly learning to align and translate (2015) Proc. Int. Conf. Learn. Repre-sent. (ICLR), pp. 1-15. , San Diego, CA, USA; Dyer, C., Ballesteros, M., Ling, W., Matthews, A., Smith, N.A., Transition-based dependency parsing with stack long short-term memory (2015) Proc. 53rd Annu. Meeting Assoc. Comput. Linguistics 7th Int. Joint Conf. Natural Lang. Process, pp. 334-343. , Beijing, China; Kazemi, V., Elqursh, A., (2017) Show, Ask, Attend, and Answer: A Strong Baseline for Visual Question Answering, , https://arxiv.org/abs/1704.03162; Mnih, V., (2013) Playing Atari with Deep Reinforcement Learning, , https://arxiv.org/abs/1312.5602; Li, N., Guo, H.-H., Zhao, Y., Li, T., Li, G., Active temporal action detection in untrimmed videos via deep reinforcement learning (2018) IEEE Access, 6, pp. 59126-