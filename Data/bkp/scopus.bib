@ARTICLE{Oltra-Mestre2021198,
author={Oltra-Mestre, M.J. and Hargaden, V. and Coughlan, P. and Segura-García del Río, B.},
title={Innovation in the Agri-Food sector: Exploiting opportunities for Industry 4.0},
journal={Creativity and Innovation Management},
year={2021},
volume={30},
number={1},
pages={198-210},
doi={10.1111/caim.12418},
note={cited By 2},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85096926071&doi=10.1111%2fcaim.12418&partnerID=40&md5=5072bbe9bbd370f47dfd745b73e03632},
affiliation={Business Administration and Marketing, Universitat Jaume I, Castellón de la Plana, Spain; School of Mechanical & Materials Engineering, University College Dublin, Dublin, Ireland; School of Business, Trinity College Dublin, Dublin, Ireland; Economics and Social Sciences, Universitat Politècnica de València, Valencia, Spain},
abstract={Agri-Food producers have a responsibility to provide safe, secure and sustainable food in a world characterized by disruption and increasing intolerance of waste along supply chains. As such, it is critical that they adopt new technologies to ensure efficient and effective management of their responsibility. While Industry 4.0 (I4.0) technologies can underpin process innovation opportunities, there is a gap in research-based understanding of how they influence innovation practice and outcomes in Agri-Food. In this paper, we investigate how I4.0, as a set of enabling technologies, influences core process innovation practice and product innovation outcomes in Agri-Food firms. We present case studies of two Spanish firms processing fresh food products, competing in two important subsectors of the industry, meat and fruit and vegetables. We used secondary material and semi-structured interviews as data sources. The findings describe how, in the two cases, I4.0 has enabled responses to new customers requirements through process innovations resulting in enhanced functionality, aesthetics and meaning of the delivered products. Our paper contributes a framework identifying for researchers and managers how I4.0 technologies act as enablers of the core innovation processes and competitive outcomes. © 2020 John Wiley & Sons Ltd},
author_keywords={Agri-Food sector;  Industry 4.0;  Process innovation;  Product innovation},
