@CONFERENCE{Moura20214,
author={Moura, A. and Antunes, J. and Dias, A. and Martins, A. and Almeida, J.},
title={Graph-SLAM Approach for Indoor UAV Localization in Warehouse Logistics Applications},
journal={2021 IEEE International Conference on Autonomous Robot Systems and Competitions, ICARSC 2021},
year={2021},
pages={4-11},
doi={10.1109/ICARSC52212.2021.9429791},
