author={Mahroof, K. and Omar, A. and Rana, N.P. and Sivarajah, U. and Weerakkody, V.},
title={Drone as a Service (DaaS) in promoting cleaner agricultural production and Circular Economy for ethical Sustainable Supply Chain development},
journal={Journal of Cleaner Production},
year={2021},
volume={287},
doi={10.1016/j.jclepro.2020.125522},
