@CONFERENCE{DeSousa2020,
author={De Sousa, A.L. and De Oliveira, A.S.},
title={Distributed MAS with Leaderless Consensus to Job-Shop Scheduler in a Virtual Smart Factory with Modular Conveyors},
journal={2020 Latin American Robotics Symposium, 2020 Brazilian Symposium on Robotics and 2020 Workshop on Robotics in Education, LARS-SBR-WRE 2020},
year={2020},
doi={10.1109/LARS/SBR/WRE51543.2020.9307149},
art_number={9307149},
note={cited By 0; Conference of 17th Latin American Robotics Symposium, 12th Brazilian Symposium on Robotics and 11th Workshop on Robotics in Education, LARS-SBR-WRE 2020 ; Conference Date: 9 November 2020 Through 12 November 2020;  Conference Code:166442},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85100298816&doi=10.1109%2fLARS%2fSBR%2fWRE51543.2020.9307149&partnerID=40&md5=51fd1bb1e3d8db9af4a52e0e7754aab4},
affiliation={Santa Catarina State University (UDESC), College of São Bento Do sul City (CEPLAN), São Bento do Sul, Santa Catarina, 89283-081, Brazil; Graduate School of Electrical Engineering and Computer Science (CPGEI), Federal Technological University of Paraná (UTFPR), Curitiba, Paraná, 80230-901, Brazil},
abstract={Increasingly intelligent and adaptable manufacturing systems are required to meet the current demands for customization and more excellent responsiveness in the factories. Multi-agent technology can be used to make these systems compatible with Industry 4.0 concepts, integrating elements of the factory that communicate and collaborate continuously, resulting in a more optimized and self-organized production. This article presents a distributed Multiagent System (MAS) that interacts with elements of a virtual Smart Factory, developing behaviors to control the production and logistics of modular conveyors at the factory. A Job Shop Scheduling algorithm, supported by a leaderless consensus mechanism, allows the execution of tasks with different processing orders. The system can pre-adjust its transport route to pass certain groups of machines in the required order. © 2020 IEEE.},
