@CONFERENCE{Koput2020197,
author={Koput, K.},
title={How artificial intelligence affect the labour market in Poland},
journal={Proceedings of the European Conference on the Impact of Artificial Intelligence and Robotics, ECIAIR 2020},
year={2020},
pages={197-202},
doi={10.34190/EAIR.20.035},
note={cited By 0; Conference of 2nd European Conference on the Impact of Artificial Intelligence and Robotics, ECIAIR 2020 ; Conference Date: 22 October 2020 Through 23 October 2020;  Conference Code:165513},
url={https://www.scopus.com/inward/record.uri?eid=2-s2.0-85097814243&doi=10.34190%2fEAIR.20.035&partnerID=40&md5=992542396be401f68a18efb396c9699e},
affiliation={The John Paul II Catholic University, Lublin, Poland},
abstract={This article analyses the impact of artificial intelligence on the labour market of Poland. This analysis is based on up-to-date papers and case studies concerning recent developments in a global labour market faced with the growing prevalence of artificial intelligence technologies and data on the national Polish labour market collected by the Central Statistical Office (GUS), Poland’s government agency in charge of collecting and publishing statistical data regarding Poland’s economy, population, and society, both nationwide and locally. This article contributes to the efforts and work of policy makers, the senior and middle managers responsible for the sourcing and deployment of AI solutions in businesses, researchers, journalists, social scientists, and enthusiasts of artificial intelligence. This paper discusses the possible ways artificial intelligence will challenge the Polish labour market. This analysis shows that Poland is a country that will have to weather the significant adverse impact of artificial intelligence growth on workforce employment. The latest data concerning the labour market of Poland forecasts a struggle with artificial intelligence solutions, with this being based on reports from leading consulting firms, private businesses, outlook papers, compilations, and academic articles. All of these aforementioned sources have been used to assess the overall potential impact of AI on the labour market. Estimates derived from this analysis demonstrate that over 10 million people in Poland who are currently employed in low-skilled positions across different sectors of the economy including public administration, healthcare, transport, and logistics, will be replaced by machines as a result of automation. Indeed, should the current workforce fail to retrain or requalify to satisfy future labour market requirements within the 10-year perspective covered by the estimates, unemployment in Poland is forecast to skyrocket to nearly 40%. However, when analysing the impact of AI and robotization on the labour market, another factor should also be taken into account, namely the so called efficiency effect, the increase of labour demands caused by the higher efficiency of industrial production. The overall result of the interaction of these opposing factors is very difficult to predict. © ECIAIR 2020.All right reserved.},
author_keywords={Artificial intelligence;  Industry 4.0;  Labour market;  Technological unemployment},
