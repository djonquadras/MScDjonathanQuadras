year={2021},
pages={807-813},
doi={10.1007/978-981-15-3639-7_97},
note={cited By 6; Conference of International Conference on Advances in Mechanical Engineering, ICAME 2020 ; Conference Date: 10 January 2020 Through 11 January 2020;  Conference Code:241809},
