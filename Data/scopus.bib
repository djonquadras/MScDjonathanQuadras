@ARTICLE{Kouadio2021,
author={Kouadio, L. and Byrareddy, V.M. and Sawadogo, A. and Newlands, N.K.},
title={Probabilistic yield forecasting of robusta coffee at the farm scale using agroclimatic and remote sensing derived indices},
