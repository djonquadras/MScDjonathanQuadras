@inproceedings{ WOS:000589702100050,
Author = {Ojo, Olumide Olajide and Zigan, Stefan and Orchard, John and Shah, Satya},
Book-Group-Author = {{IEEE}},
Title = {{Advanced Technology Integration in Food Manufacturing Supply Chain
   Environment: Pathway to Sustainability and Companies' Prosperity}},
Booktitle = {{2019 IEEE TECHNOLOGY \& ENGINEERING MANAGEMENT CONFERENCE (TEMSCON)}},
Year = {{2019}},
Note = {{IEEE Technology and Engineering Management Conference (TEMSCON), GTRI,
   Atlanta, GA, JUN 11-14, 2019}},
Organization = {{IEEE; IEEE Technol \& Engn Management Soc}},
Abstract = {{The applicability of trends in industries' production, logistics and
   supply chain management has increased productivity, efficiency and less
   adverse environmental impact. Sustainability is one of the trends
   identified and percept by various researches as what every industry
   could consider ensuring a better future for the environment and
   prosperity in most sectors. Meanwhile, the application of different new
   technologies and the current digitalization is helping in achieving the
   said sustainability trends within the manufacturing industry. This
   study, therefore, aims to investigate through literatures and a case
   study how well integration of advanced technology has impacted
   sustainability and growth within food manufacturing environment.
   Integration of advanced technology to aid sustainability within food
   manufacturing and supply chain environment will be investigated through
   a case study in an agricultural-livestock cooperative company in
   Andalusia, Spain. Meanwhile, with the combination of the literature
   review carried out and the explorative research through case study where
   specialists and experts in sustainability, food manufacturing and supply
   chain management were interviewed. The research was able to highlight
   the impacts of the innovations and integration of advanced technology
   within food manufacturing and supply chain environment with a brief
   sustainability evaluation using the analysis of the company's KPI.}},
Publisher = {{IEEE}},
Address = {{345 E 47TH ST, NEW YORK, NY 10017 USA}},
Type = {{Proceedings Paper}},
Language = {{English}},
Affiliation = {{Ojo, OO (Corresponding Author), Univ Greenwich, Fac Engn Sci, Dept Appl Engn \& Management, London, England.
   Ojo, Olumide Olajide; Zigan, Stefan, Univ Greenwich, Fac Engn Sci, Dept Appl Engn \& Management, London, England.
