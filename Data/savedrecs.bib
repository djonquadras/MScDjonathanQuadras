
@inproceedings{ WOS:000460605600003,
Author = {Pilinkiene, V. and Gruzauskas, V. and Navickas, V.},
Editor = {{Gaol, FL and Hutagalung, F and Peng, CF and Isa, ZM and Rushdan, AR}},
Title = {{Lean thinking and Industry 4.0 competitiveness strategy: Sustainable
   food supply chain in the European Union}},
Booktitle = {{TRENDS AND ISSUES IN INTERDISCIPLINARY BEHAVIOR AND SOCIAL SCIENCE}},
Year = {{2017}},
Pages = {{15-20}},
Note = {{5th International Congress on Interdisciplinary Behavior and Social
   Science (ICIBSoS), Jogjakarta, INDONESIA, NOV 05-06, 2016}},
Abstract = {{In the European Union 49.6\% of the whole food demand is being fulfilled
   by small and medium farmers. The developed Common Agriculture Policy
   (CAP) is aimed to guarantee the market for small and medium farmers;
   however, the government is obligated to also pay for the surplus. A
   large proportion of the food products are being exported to other
   markets at much lower prices, or are passing their expiry dates and are
   considered as waste. Due to this problem, the authors developed a case
   study of the European Union food industry by modeling different logistic
   network scenarios, and implemented a competitiveness strategy based on
   the Industry 4.0 concept and lean philosophy. The methodology of this
   paper consisted of literature analysis, specialist interview, and
   mathematical modeling by using Rstudio and simulated annealing
   algorithm. The authors' results showed that by implementing a logistic
   cluster in the EU and by using the developed competitiveness strategy, a
   sustainable supply chain can be achieved, together with low management
   costs and visibility of the whole food chain.}},
